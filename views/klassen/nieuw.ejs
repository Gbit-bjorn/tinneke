<%- include('../partials/head', { title: 'Nieuwe klas', activePage: 'klassen' }) %>

<!-- ── Breadcrumb ── -->
<div style="margin-bottom:8px;">
  <a href="/klassen" style="font-size:13px; font-weight:600; color:#1E3A8A; text-decoration:none; display:inline-flex; align-items:center; gap:4px;"
     onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">
    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
    Alle klassen
  </a>
</div>

<!-- ── Flash messages ── -->
<% if (typeof flash !== 'undefined' && flash) { %>
  <% if (flash.success) { %>
    <div class="alert alert-success" style="margin-bottom:16px; max-width:520px;"><%= flash.success %></div>
  <% } %>
  <% if (flash.error) { %>
    <div class="alert alert-error" style="margin-bottom:16px; max-width:520px;"><%= flash.error %></div>
  <% } %>
<% } %>

<div style="max-width:520px;">
  <h1 style="font-size:24px; font-weight:700; color:#0F172A; margin:0 0 4px 0;">Nieuwe klas aanmaken</h1>
  <p style="font-size:14px; color:#475569; margin:0 0 24px 0;">Vul de gegevens in om een klas toe te voegen.</p>

  <div class="card" style="padding:28px;">

    <!-- Foutmelding -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error" style="margin-bottom:20px;">
        <%= error %>
      </div>
    <% } %>

    <form action="/klassen/nieuw" method="POST" novalidate>

      <!-- Naam -->
      <div style="margin-bottom:18px;">
        <label for="naam" style="display:block; font-size:13px; font-weight:600; color:#0F172A; margin-bottom:5px;">
          Klasnaam <span style="color:#EF4444;">*</span>
        </label>
        <input
          type="text"
          id="naam"
          name="naam"
          class="input"
          placeholder="bijv. 3BEI"
          value="<%= typeof formData !== 'undefined' ? formData.naam || '' : '' %>"
          required
          maxlength="50"
          autofocus
        />
        <p style="font-size:12px; color:#94A3B8; margin:4px 0 0 0;">De gebruikelijke klascode of naam.</p>
      </div>

      <!-- Richting -->
      <div style="margin-bottom:18px;">
        <label for="richting" style="display:block; font-size:13px; font-weight:600; color:#0F172A; margin-bottom:5px;">
          Studierichting
        </label>
        <input
          type="text"
          id="richting"
          name="richting"
          class="input"
          placeholder="bijv. Elektriciteit-Installatie"
          value="<%= typeof formData !== 'undefined' ? formData.richting || '' : '' %>"
          maxlength="100"
        />
        <p style="font-size:12px; color:#94A3B8; margin:4px 0 0 0;">Optioneel &mdash; de naam van de opleiding.</p>
      </div>

      <!-- Schooljaar -->
      <div style="margin-bottom:28px;">
        <label for="schooljaar" style="display:block; font-size:13px; font-weight:600; color:#0F172A; margin-bottom:5px;">
          Schooljaar <span style="color:#EF4444;">*</span>
        </label>
        <input
          type="number"
          id="schooljaar"
          name="schooljaar"
          class="input"
          placeholder="<%= new Date().getFullYear() %>"
          value="<%= typeof formData !== 'undefined' ? formData.schooljaar || new Date().getFullYear() : new Date().getFullYear() %>"
          min="2020"
          max="2040"
          required
        />
        <p style="font-size:12px; color:#94A3B8; margin:4px 0 0 0;">
          Vul het eerste jaar in, bijv. <strong><%= new Date().getFullYear() %></strong>
          voor schooljaar <%= new Date().getFullYear() %>&ndash;<%= new Date().getFullYear() + 1 %>.
        </p>
      </div>

      <!-- Knoppen -->
      <div style="display:flex; gap:10px;">
        <a href="/klassen" class="btn btn-secondary" style="flex:1; min-height:44px; justify-content:center;">
          Annuleer
        </a>
        <button type="submit" class="btn btn-primary" style="flex:1; min-height:44px; justify-content:center; gap:8px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Aanmaken
        </button>
      </div>

    </form>
  </div>
</div>

<%- include('../partials/footer') %>
