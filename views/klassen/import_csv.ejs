<%- include('../partials/head', { title: 'CSV importeren — ' + klas.naam, activePage: 'klassen' }) %>

<!-- ── Breadcrumb ── -->
<div style="margin-bottom:8px; display:flex; align-items:center; gap:6px; font-size:13px; color:#475569;">
  <a href="/klassen" style="font-weight:600; color:#1E3A8A; text-decoration:none;"
     onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">Klassen</a>
  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="#94A3B8">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
  </svg>
  <a href="/klassen/<%= klas.id %>" style="font-weight:600; color:#1E3A8A; text-decoration:none;"
     onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'"><%= klas.naam %></a>
  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="#94A3B8">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
  </svg>
  <span>CSV importeren</span>
</div>

<!-- ── Flash messages ── -->
<% if (typeof flash !== 'undefined' && flash) { %>
  <% if (flash.success) { %>
    <div class="alert alert-success" style="margin-bottom:16px; max-width:680px;"><%= flash.success %></div>
  <% } %>
  <% if (flash.error) { %>
    <div class="alert alert-error" style="margin-bottom:16px; max-width:680px;"><%= flash.error %></div>
  <% } %>
<% } %>

<div style="max-width:680px;">
  <h1 style="font-size:24px; font-weight:700; color:#0F172A; margin:0 0 4px 0;">CSV importeren</h1>
  <p style="font-size:14px; color:#475569; margin:0 0 24px 0;">
    Importeer leerlingen voor <strong style="color:#0F172A;"><%= klas.naam %></strong> via een puntkomma-gescheiden bestand.
  </p>

  <!-- ── Uitlegkaart ── -->
  <div class="card" style="padding:18px 20px; margin-bottom:20px; background:#F8FAFF; border-left:3px solid #1E3A8A;">
    <div style="display:flex; align-items:flex-start; gap:14px;">
      <div style="width:36px; height:36px; background:#EFF6FF; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" fill="none" viewBox="0 0 24 24" stroke="#1E3A8A">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z" />
        </svg>
      </div>
      <div>
        <h3 style="font-size:14px; font-weight:700; color:#0F172A; margin:0 0 6px 0;">Verwacht bestandsformaat</h3>
        <p style="font-size:13px; color:#475569; margin:0 0 10px 0;">
          Puntkomma-gescheiden <code style="background:#EFF6FF; padding:1px 5px; border-radius:4px; font-size:12px; color:#1E3A8A;">.csv</code>
          met minstens de kolommen
          <code style="background:#EFF6FF; padding:1px 5px; border-radius:4px; font-size:12px; font-family:monospace; color:#1E3A8A;">naam</code> en
          <code style="background:#EFF6FF; padding:1px 5px; border-radius:4px; font-size:12px; font-family:monospace; color:#1E3A8A;">voornaam</code>.
          Bestaande leerlingen worden <strong>overschreven</strong>.
        </p>
        <div style="background:#FFFFFF; border:1px solid #E2E8F0; border-radius:8px; padding:10px 14px; font-family:monospace; font-size:12px; color:#334155; line-height:1.8;">
          <span style="color:#94A3B8;"># voorbeeld.csv</span><br>
          <span style="font-weight:700; color:#1E3A8A;">naam;voornaam</span><br>
          Janssen;Lars<br>
          Peeters;Emma<br>
          De Smedt;Nathalie
        </div>
        <p style="font-size:12px; color:#64748B; margin:8px 0 0 0;">
          Kolommen mogen in willekeurige volgorde staan. Extra kolommen worden genegeerd.
        </p>
      </div>
    </div>
  </div>

  <!-- ── Upload formulier ── -->
  <div class="card" style="padding:24px;">

    <!-- Foutmelding -->
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-error" style="margin-bottom:20px;">
        <%= error %>
      </div>
    <% } %>

    <form action="/klassen/<%= klas.id %>/importeer" method="POST" enctype="multipart/form-data" id="import-form">

      <!-- Tab keuze -->
      <div style="display:flex; background:#F1F5F9; border-radius:10px; padding:4px; margin-bottom:22px;" role="tablist">
        <button type="button" id="tab-file" role="tab"
                onclick="switchTab('file')"
                style="flex:1; padding:9px 16px; border-radius:7px; font-size:13px; font-weight:600; border:none; cursor:pointer; transition:all 0.15s; background:#FFFFFF; color:#1E3A8A; box-shadow:0 1px 4px rgba(0,0,0,0.1);">
          Bestand uploaden
        </button>
        <button type="button" id="tab-text" role="tab"
                onclick="switchTab('text')"
                style="flex:1; padding:9px 16px; border-radius:7px; font-size:13px; font-weight:600; border:none; cursor:pointer; transition:all 0.15s; background:transparent; color:#64748B; box-shadow:none;">
          Tekst plakken
        </button>
      </div>

      <!-- Bestand upload panel -->
      <div id="panel-file">
        <label for="csv_file" style="display:block; font-size:13px; font-weight:600; color:#0F172A; margin-bottom:8px;">
          CSV-bestand
        </label>
        <div id="drop-zone"
             onclick="document.getElementById('csv_file').click()"
             style="border:2px dashed #CBD5E1; border-radius:10px; padding:36px 24px; text-align:center; cursor:pointer; transition:border-color 0.15s, background 0.15s;"
             onmouseover="this.style.borderColor='#1E3A8A'; this.style.background='#F0F6FF';"
             onmouseout="if(!this.classList.contains('actief')) { this.style.borderColor='#CBD5E1'; this.style.background=''; }">
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="#94A3B8"
               style="display:block; margin:0 auto 12px auto;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
          </svg>
          <p style="font-size:14px; font-weight:600; color:#334155; margin:0 0 4px 0;">Klik om een bestand te kiezen</p>
          <p style="font-size:12px; color:#94A3B8; margin:0;">of sleep het hiernaartoe &mdash; .csv of .txt</p>
          <p id="file-name" style="margin:10px 0 0 0; font-size:13px; font-weight:600; color:#1E3A8A; display:none;"></p>
        </div>
        <input type="file" id="csv_file" name="csv_file" accept=".csv,.txt" style="display:none;" onchange="showFileName(this)" />
      </div>

      <!-- Tekst plakken panel -->
      <div id="panel-text" style="display:none;">
        <label for="csv_text" style="display:block; font-size:13px; font-weight:600; color:#0F172A; margin-bottom:8px;">
          CSV-inhoud
        </label>
        <textarea
          id="csv_text"
          name="csv_text"
          class="input"
          rows="10"
          placeholder="naam;voornaam&#10;Janssen;Lars&#10;Peeters;Emma"
          style="font-family:monospace; font-size:13px; resize:vertical; min-height:180px;"
        ></textarea>
        <p style="font-size:12px; color:#94A3B8; margin:5px 0 0 0;">Plak de volledige CSV-inhoud inclusief de headerrij.</p>
      </div>

      <!-- Actieknoppen -->
      <div style="display:flex; gap:10px; margin-top:24px;">
        <a href="/klassen/<%= klas.id %>" class="btn btn-secondary" style="flex:1; min-height:44px; justify-content:center;">
          Annuleer
        </a>
        <button type="submit" class="btn btn-primary" style="flex:1; min-height:44px; justify-content:center; gap:8px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
          </svg>
          Importeer leerlingen
        </button>
      </div>

    </form>
  </div>
</div>

<script>
  function switchTab(tab) {
    const filePanel = document.getElementById('panel-file');
    const textPanel = document.getElementById('panel-text');
    const fileTab   = document.getElementById('tab-file');
    const textTab   = document.getElementById('tab-text');

    const actief = { background: '#FFFFFF', color: '#1E3A8A', boxShadow: '0 1px 4px rgba(0,0,0,0.1)' };
    const inactief = { background: 'transparent', color: '#64748B', boxShadow: 'none' };

    if (tab === 'file') {
      filePanel.style.display = '';
      textPanel.style.display = 'none';
      Object.assign(fileTab.style, actief);
      Object.assign(textTab.style, inactief);
    } else {
      filePanel.style.display = 'none';
      textPanel.style.display = '';
      Object.assign(textTab.style, actief);
      Object.assign(fileTab.style, inactief);
    }
  }

  function showFileName(input) {
    const label   = document.getElementById('file-name');
    const dropZone = document.getElementById('drop-zone');
    if (input.files && input.files[0]) {
      label.textContent = input.files[0].name;
      label.style.display = 'block';
      dropZone.style.borderColor = '#1E3A8A';
      dropZone.style.background  = '#EFF6FF';
      dropZone.classList.add('actief');
    }
  }

  /* Drag & drop */
  const dropZone = document.getElementById('drop-zone');

  dropZone.addEventListener('dragover', function (e) {
    e.preventDefault();
    dropZone.style.borderColor = '#1E3A8A';
    dropZone.style.background  = '#EFF6FF';
  });

  dropZone.addEventListener('dragleave', function () {
    if (!dropZone.classList.contains('actief')) {
      dropZone.style.borderColor = '#CBD5E1';
      dropZone.style.background  = '';
    }
  });

  dropZone.addEventListener('drop', function (e) {
    e.preventDefault();
    const fileInput = document.getElementById('csv_file');
    fileInput.files = e.dataTransfer.files;
    showFileName(fileInput);
  });
</script>

<%- include('../partials/footer') %>
