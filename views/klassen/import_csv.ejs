<%- include('../partials/head', { title: 'CSV importeren — ' + klas.naam, activePage: 'klassen' }) %>

<!-- ── Breadcrumb ── -->
<div class="mb-2 flex items-center gap-2 text-sm text-slate-500">
  <a href="/klassen" class="text-primary font-semibold hover:underline">Klassen</a>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
  </svg>
  <a href="/klassen/<%= klas.id %>" class="text-primary font-semibold hover:underline"><%= klas.naam %></a>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
  </svg>
  <span>CSV importeren</span>
</div>

<div class="max-w-2xl">
  <h1 class="font-heading text-4xl font-bold text-ink mb-1">CSV importeren</h1>
  <p class="text-slate-500 mb-8">
    Importeer leerlingen voor <strong><%= klas.naam %></strong> via een puntkomma-gescheiden bestand.
  </p>

  <!-- ── Uitlegkaart ── -->
  <div class="clay-card p-6 mb-6" style="background: linear-gradient(135deg, #EFF6FF 0%, #F0FDF4 100%);">
    <div class="flex items-start gap-4">
      <div class="w-10 h-10 bg-blue-100 rounded-clays flex items-center justify-center flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20A10 10 0 0012 2z" />
        </svg>
      </div>
      <div>
        <h3 class="font-heading text-lg font-semibold text-ink mb-2">Verwacht formaat</h3>
        <p class="text-slate-600 text-sm mb-3">
          Het bestand moet puntkomma-gescheiden zijn (<code class="bg-white px-1 rounded text-xs">.csv</code>)
          met een header-rij en minstens de kolommen <code class="bg-white px-1 rounded text-xs font-mono">naam</code>
          en <code class="bg-white px-1 rounded text-xs font-mono">voornaam</code>.
        </p>
        <div class="bg-white rounded-xl p-3 font-mono text-xs text-slate-700 border border-slate-200">
          <div class="text-slate-400 mb-1"># voorbeeld.csv</div>
          <div class="font-bold text-primary">naam;voornaam</div>
          <div>Janssen;Lars</div>
          <div>Peeters;Emma</div>
          <div>De Smedt;Nathalie</div>
        </div>
        <p class="text-slate-500 text-xs mt-2">
          Kolommen mogen in willekeurige volgorde staan. Extra kolommen worden genegeerd.
          Bestaande leerlingen van deze klas worden <strong>overschreven</strong>.
        </p>
      </div>
    </div>
  </div>

  <!-- ── Upload formulier ── -->
  <div class="clay-card p-8">

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mb-6 p-3 bg-red-50 border-2 border-red-100 rounded-xl flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
        <span class="text-red-700 font-semibold text-sm"><%= error %></span>
      </div>
    <% } %>

    <form action="/klassen/<%= klas.id %>/importeer" method="POST" enctype="multipart/form-data" id="import-form">

      <!-- Tab keuze -->
      <div class="flex rounded-xl bg-slate-100 p-1 mb-6" role="tablist">
        <button type="button" id="tab-file" role="tab"
                class="flex-1 py-2 px-4 rounded-lg text-sm font-bold transition-all tab-active"
                onclick="switchTab('file')"
                style="background:white; color:#2563EB; box-shadow: 0 2px 6px rgba(37,99,235,0.15);">
          Bestand uploaden
        </button>
        <button type="button" id="tab-text" role="tab"
                class="flex-1 py-2 px-4 rounded-lg text-sm font-bold transition-all"
                onclick="switchTab('text')"
                style="background:transparent; color:#64748B;">
          Tekst plakken
        </button>
      </div>

      <!-- Bestand upload -->
      <div id="panel-file">
        <label for="csv_file" class="block text-sm font-bold text-slate-700 mb-2">
          CSV-bestand
        </label>
        <div id="drop-zone"
             class="border-2 border-dashed border-slate-300 rounded-xl p-8 text-center cursor-pointer transition-all hover:border-primary hover:bg-blue-50"
             onclick="document.getElementById('csv_file').click()">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-slate-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
          </svg>
          <p class="text-slate-600 font-semibold text-sm mb-1">Klik om een bestand te kiezen</p>
          <p class="text-slate-400 text-xs">of sleep het hiernaartoe</p>
          <p id="file-name" class="mt-3 text-primary text-sm font-semibold hidden"></p>
        </div>
        <input type="file" id="csv_file" name="csv_file" accept=".csv,.txt" class="hidden" onchange="showFileName(this)" />
      </div>

      <!-- Tekst plakken -->
      <div id="panel-text" class="hidden">
        <label for="csv_text" class="block text-sm font-bold text-slate-700 mb-2">
          CSV-inhoud
        </label>
        <textarea
          id="csv_text"
          name="csv_text"
          class="clay-input font-mono text-sm"
          rows="10"
          placeholder="naam;voornaam&#10;Janssen;Lars&#10;Peeters;Emma"
          style="resize: vertical;"
        ></textarea>
      </div>

      <div class="flex gap-3 mt-8">
        <a href="/klassen/<%= klas.id %>" class="clay-btn clay-btn-secondary flex-1 justify-center">
          Annuleer
        </a>
        <button type="submit" class="clay-btn clay-btn-cta flex-1 justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
          </svg>
          Importeer leerlingen
        </button>
      </div>

    </form>
  </div>
</div>

<script>
  function switchTab(tab) {
    const filePanel = document.getElementById('panel-file');
    const textPanel = document.getElementById('panel-text');
    const fileTab   = document.getElementById('tab-file');
    const textTab   = document.getElementById('tab-text');

    if (tab === 'file') {
      filePanel.classList.remove('hidden');
      textPanel.classList.add('hidden');
      fileTab.style.background = 'white';
      fileTab.style.color = '#2563EB';
      fileTab.style.boxShadow = '0 2px 6px rgba(37,99,235,0.15)';
      textTab.style.background = 'transparent';
      textTab.style.color = '#64748B';
      textTab.style.boxShadow = 'none';
    } else {
      filePanel.classList.add('hidden');
      textPanel.classList.remove('hidden');
      textTab.style.background = 'white';
      textTab.style.color = '#2563EB';
      textTab.style.boxShadow = '0 2px 6px rgba(37,99,235,0.15)';
      fileTab.style.background = 'transparent';
      fileTab.style.color = '#64748B';
      fileTab.style.boxShadow = 'none';
    }
  }

  function showFileName(input) {
    const label = document.getElementById('file-name');
    if (input.files && input.files[0]) {
      label.textContent = input.files[0].name;
      label.classList.remove('hidden');
      document.getElementById('drop-zone').style.borderColor = '#2563EB';
      document.getElementById('drop-zone').style.background = '#EFF6FF';
    }
  }

  // Drag & drop
  const dropZone = document.getElementById('drop-zone');
  dropZone.addEventListener('dragover', function(e) {
    e.preventDefault();
    dropZone.style.borderColor = '#2563EB';
    dropZone.style.background = '#EFF6FF';
  });
  dropZone.addEventListener('dragleave', function() {
    dropZone.style.borderColor = '#CBD5E1';
    dropZone.style.background = '';
  });
  dropZone.addEventListener('drop', function(e) {
    e.preventDefault();
    const fileInput = document.getElementById('csv_file');
    fileInput.files = e.dataTransfer.files;
    showFileName(fileInput);
  });
</script>

<%- include('../partials/footer') %>
