<%- include('../partials/head', {title: leerling.naam + ' ' + leerling.voornaam + ' — Attestering', activePage: 'klassen'}) %>

  <style>
    .progress-track { background: #E2E8F0; border-radius: 999px; height: 5px; overflow: hidden; }
    .progress-fill { background: #1E3A8A; height: 100%; border-radius: 999px; transition: width 300ms ease; }
    .progress-fill.partial { background: #93C5FD; }
    .lpd-label.behaald { text-decoration: line-through; color: #94A3B8; }
    .bk-toggle-icon { transition: transform 200ms; display: inline-block; }
    .bk-toggle-icon.open { transform: rotate(90deg); }
    @media (max-width: 640px) { .attestering-header { flex-direction: column; gap: 12px; } }

    #toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      padding: 10px 18px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      opacity: 0;
      pointer-events: none;
      transition: opacity 250ms ease;
      z-index: 9999;
    }
    #toast.show { opacity: 1; }
    #toast.ok  { background: #D1FAE5; color: #065F46; border: 1px solid #6EE7B7; }
    #toast.err { background: #FEE2E2; color: #991B1B; border: 1px solid #FCA5A5; }

    /* ── Tab navigatie ── */
    .tab-nav {
      display: flex;
      gap: 0;
      border-bottom: 2px solid #E2E8F0;
      margin-bottom: 20px;
    }
    .tab-btn {
      padding: 9px 22px;
      border: none;
      border-bottom: 2px solid transparent;
      background: transparent;
      font-family: 'Inter', sans-serif;
      font-size: 0.875rem;
      font-weight: 600;
      color: #64748B;
      cursor: pointer;
      margin-bottom: -2px;
      transition: color 150ms, border-color 150ms;
      white-space: nowrap;
    }
    .tab-btn:hover { color: #1E3A8A; }
    .tab-btn.active {
      color: #1E3A8A;
      border-bottom-color: #1E3A8A;
    }

    /* ── LPD flat list ── */
    .lpd-groep-header {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #94A3B8;
      padding: 10px 0 4px;
      border-top: 1px solid #F1F5F9;
      margin-top: 4px;
    }
    .lpd-groep-header:first-child {
      border-top: none;
      margin-top: 0;
      padding-top: 4px;
    }
    .lpd-flat-item {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 7px 8px;
      border-radius: 6px;
      transition: background 100ms;
    }
    .lpd-flat-item:hover { background: #F8FAFC; }
    .lpd-nr {
      font-size: 0.75rem;
      font-weight: 700;
      color: #1E3A8A;
      min-width: 28px;
      text-align: right;
      flex-shrink: 0;
      padding-top: 1px;
    }
  </style>

  <!-- Header -->
  <div class="attestering-header" style="display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:24px; gap:16px; flex-wrap:wrap;">
    <div>
      <h1 style="font-size:1.75rem; font-weight:700; color:#0F172A; margin:0 0 4px;">
        <%= leerling.voornaam %> <%= leerling.naam %>
      </h1>
      <p style="font-size:0.875rem; color:#475569; margin:0;">
        <span style="font-weight:600; color:#1E3A8A;"><%= klas.naam %></span>
        <% if (klas.richting) { %>
          <span style="margin:0 6px; color:#CBD5E1;">&middot;</span><%= klas.richting %>
        <% } %>
      </p>
    </div>

    <div style="display:flex; gap:8px; flex-wrap:wrap;">
      <a href="/export/<%= leerling.id %>"
         class="btn btn-secondary btn-sm"
         style="display:inline-flex; align-items:center; gap:6px; min-height:44px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Export
      </a>
      <a href="/klassen/<%= typeof klasId !== 'undefined' && klasId ? klasId : '' %>"
         class="btn btn-secondary btn-sm"
         style="display:inline-flex; align-items:center; gap:6px; min-height:44px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Terug naar klas
      </a>
    </div>
  </div>

  <!-- Geen leerplan -->
  <% if (!leerplanUuid) { %>
    <div class="card" style="padding:24px; color:#475569; font-size:0.9rem; display:flex; align-items:center; gap:12px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#94A3B8" stroke-width="2" style="flex-shrink:0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span>Geen leerplan gekoppeld aan deze klas. Koppel eerst een leerplan via het klassenbeheer.</span>
    </div>
  <% } else if (typeof llinkidFout !== 'undefined' && llinkidFout) { %>
    <div class="card" style="padding:24px; color:#991B1B; background:#FEF2F2; font-size:0.9rem; display:flex; align-items:center; gap:12px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#DC2626" stroke-width="2" style="flex-shrink:0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <span>Fout bij ophalen doelen van LLinkid: <%= llinkidFout %></span>
    </div>
  <% } else if (bkSecties.length === 0) { %>
    <div class="card" style="padding:24px; color:#475569; font-size:0.9rem; display:flex; align-items:center; gap:12px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#94A3B8" stroke-width="2" style="flex-shrink:0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      <span>Geen doelen gevonden voor dit leerplan.</span>
    </div>
  <% } else { %>

  <!-- Tab navigatie -->
  <div class="tab-nav">
    <button type="button" class="tab-btn active" id="tab-btn-lpd" onclick="setTab('lpd')">LPD's</button>
    <button type="button" class="tab-btn"        id="tab-btn-bk"  onclick="setTab('bk')">BK's</button>
  </div>

  <!-- ══════════════════════════════════════════════════ -->
  <!-- TAB 1: Platte LPD-lijst (werkweergave)            -->
  <!-- ══════════════════════════════════════════════════ -->
  <div id="tab-lpd" class="card" style="padding:12px 16px;">

    <%
      /* Bouw een gesorteerde, platte lijst van alle LPDs op server-side.
         Elk LPD krijgt bk.key + dpk.key mee als data-attributen zodat
         _herbereken() de checkboxes nog steeds kan vinden. */
    %>

    <% bkSecties.forEach(function(bk) { %>

      <!-- BK-groepheader in de platte lijst -->
      <div class="lpd-groep-header">
        BK: <%= bk.titel || bk.key %>
      </div>

      <% bk.dpkSecties.forEach(function(dpk) { %>

        <!-- DPK-subheader (compact, ingesprongen) — verberg bij synthetische DPK (zelfde titel als BK) -->
        <% if (!dpk.synthetic && (dpk.titel || dpk.key)) { %>
          <div style="font-size:0.75rem; font-weight:600; color:#CBD5E1; padding:2px 0 2px 8px; margin-bottom:2px;">
            <span style="margin-right:4px; color:#E2E8F0;">&#x2514;</span><%= dpk.titel || dpk.key %>
          </div>
        <% } %>

        <% dpk.lpds.forEach(function(lpd) { %>
          <div class="lpd-flat-item"
               data-lpd-key="<%= lpd.key %>"
               data-bk-key="<%= bk.key %>"
               data-dpk-key="<%= dpk.key %>">

            <input
              type="checkbox"
              id="lpd-flat-<%= lpd.key %>"
              style="margin-top:2px; width:16px; height:16px; accent-color:#1E3A8A; cursor:pointer; flex-shrink:0;"
              <%= lpd.behaald ? 'checked' : '' %>
              onchange="toggleLpd(this, '<%= lpd.key %>', '<%= leerling.id %>')"
            />

            <span class="lpd-nr"><%= lpd.nr %></span>

            <label
              for="lpd-flat-<%= lpd.key %>"
              class="lpd-label<%= lpd.behaald ? ' behaald' : '' %>"
              style="font-size:0.875rem; cursor:pointer; line-height:1.4; flex:1;">
              <%= lpd.titel %>
            </label>

          </div>
        <% }); %>

      <% }); %>

    <% }); %>

  </div><!-- /tab-lpd -->


  <!-- ══════════════════════════════════════════════════ -->
  <!-- TAB 2: BK-overzicht (leesweergave)               -->
  <!-- ══════════════════════════════════════════════════ -->
  <div id="tab-bk" style="display:none; flex-direction:column; gap:12px;">

    <% bkSecties.forEach(function(bk) { %>

      <div class="card" style="overflow:hidden;" data-bk-key="<%= bk.key %>">

        <!-- BK header (klikbaar) -->
        <button
          type="button"
          onclick="toggleBk(this)"
          aria-expanded="true"
          style="width:100%; display:flex; align-items:center; gap:10px; padding:14px 16px; background:#EFF6FF; border:none; cursor:pointer; text-align:left; border-bottom:1px solid #DBEAFE;"
        >
          <span class="bk-toggle-icon open" style="color:#1E3A8A; font-size:11px; flex-shrink:0;">&#9654;</span>
          <span style="font-weight:600; color:#1E3A8A; flex:1; font-size:0.9375rem;">
            BK: <%= bk.titel || bk.key %>
          </span>
          <!-- BK Behaald badge -->
          <span
            data-bk-badge="<%= bk.key %>"
            style="display:<%= bk.stats.percentage === 100 ? 'inline-flex' : 'none' %>; align-items:center; background:#D1FAE5; color:#065F46; padding:3px 10px; border-radius:999px; font-size:11px; font-weight:700; white-space:nowrap; margin-right:8px;">
            &#10003; Behaald
          </span>
          <!-- BK voortgangsindicator -->
          <span
            data-bk-stats="<%= bk.key %>"
            style="font-size:13px; color:#475569; white-space:nowrap; flex-shrink:0;">
            <%= bk.stats.behaald %>/<%= bk.stats.totaal %>
          </span>
        </button>

        <!-- BK voortgangsbalk -->
        <div style="padding:0 16px 8px; background:#EFF6FF;">
          <div class="progress-track" style="margin-top:6px;">
            <div
              class="progress-fill<%= bk.stats.percentage < 100 ? ' partial' : '' %>"
              style="width:<%= bk.stats.percentage %>%"
              data-bk-bar="<%= bk.key %>">
            </div>
          </div>
        </div>

        <!-- BK body (collapsible) -->
        <div class="bk-body" style="padding:16px; display:flex; flex-direction:column; gap:16px;">

          <% bk.dpkSecties.forEach(function(dpk) { %>
            <div data-dpk-key="<%= dpk.key %>">

              <!-- DPK header — verberg bij synthetische DPK (zelfde titel als BK) -->
              <% if (!dpk.synthetic) { %>
              <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
                <span style="color:#94A3B8; font-size:11px; flex-shrink:0;">&#x2523;</span>
                <span style="font-weight:600; font-size:0.875rem; color:#0F172A; flex:1;">
                  DPK: <%= dpk.titel || dpk.key %>
                </span>
                <!-- DPK behaald vink -->
                <span
                  data-dpk-badge="<%= dpk.key %>"
                  style="display:<%= dpk.stats.percentage === 100 ? 'inline' : 'none' %>; color:#059669; font-size:13px; font-weight:700;">
                  &#10003;
                </span>
                <span
                  data-dpk-stats="<%= dpk.key %>"
                  style="font-size:12px; font-weight:600; color:<%= dpk.stats.percentage === 100 ? '#059669' : '#94A3B8' %>; white-space:nowrap; flex-shrink:0;">
                  <%= dpk.stats.behaald %>/<%= dpk.stats.totaal %>
                </span>
              </div>

              <!-- DPK voortgangsbalk -->
              <div class="progress-track" style="margin-bottom:10px; margin-left:16px;">
                <div
                  class="progress-fill<%= dpk.stats.percentage < 100 ? ' partial' : '' %>"
                  style="width:<%= dpk.stats.percentage %>%"
                  data-dpk-bar="<%= dpk.key %>">
                </div>
              </div>
              <% } %>

              <!-- LPD regels (read-only, geen checkboxes) -->
              <ul style="list-style:none; margin:0 0 0 16px; padding:0; display:flex; flex-direction:column; gap:5px;">
                <% dpk.lpds.forEach(function(lpd) { %>
                  <li style="display:flex; align-items:flex-start; gap:8px;"
                      data-lpd-key="<%= lpd.key %>"
                      data-bk-key="<%= bk.key %>"
                      data-dpk-key="<%= dpk.key %>">

                    <!-- Status-icoon (readonly) -->
                    <span style="margin-top:2px; flex-shrink:0; width:16px; text-align:center; font-size:13px; color:<%= lpd.behaald ? '#059669' : '#CBD5E1' %>;">
                      <%= lpd.behaald ? '✓' : '○' %>
                    </span>

                    <span
                      class="lpd-label<%= lpd.behaald ? ' behaald' : '' %>"
                      style="font-size:0.875rem; line-height:1.4;">
                      <span style="font-weight:700; color:#1E3A8A; margin-right:4px;">LPD <%= lpd.nr %>:</span><%= lpd.titel %>
                    </span>

                  </li>
                <% }); %>
              </ul>

            </div>
          <% }); %>

        </div><!-- /bk-body -->
      </div><!-- /card -->

    <% }); %>

  </div><!-- /tab-bk -->

  <% } %>

  <!-- Toast -->
  <div id="toast" role="status" aria-live="polite"></div>

  <script>
    // ── Tab-switching ──
    function setTab(naam) {
      var tabLpd = document.getElementById('tab-lpd');
      var tabBk  = document.getElementById('tab-bk');
      var btnLpd = document.getElementById('tab-btn-lpd');
      var btnBk  = document.getElementById('tab-btn-bk');

      if (naam === 'lpd') {
        tabLpd.style.display = '';
        tabBk.style.display  = 'none';
        btnLpd.classList.add('active');
        btnBk.classList.remove('active');
      } else {
        tabLpd.style.display = 'none';
        tabBk.style.display  = 'flex';
        btnLpd.classList.remove('active');
        btnBk.classList.add('active');
      }
    }

    // Collapse / expand BK-sectie (alleen in tab BK's)
    function toggleBk(btn) {
      const card = btn.closest('[data-bk-key]');
      const body = card.querySelector('.bk-body');
      const icon = btn.querySelector('.bk-toggle-icon');
      const open = btn.getAttribute('aria-expanded') === 'true';

      if (open) {
        body.style.display = 'none';
        btn.setAttribute('aria-expanded', 'false');
        icon.classList.remove('open');
      } else {
        body.style.display = '';
        btn.setAttribute('aria-expanded', 'true');
        icon.classList.add('open');
      }
    }

    // AJAX toggle LPD
    async function toggleLpd(checkbox, lpdUuid, leerlingId) {
      const behaald = checkbox.checked;

      // Optimistisch UI — sync beide tabs
      // Tab 1: label van de aangeklikte checkbox
      const flatLabel = document.querySelector(`label[for="lpd-flat-${lpdUuid}"]`);
      if (flatLabel) flatLabel.classList.toggle('behaald', behaald);

      // Tab 2: read-only status-icoon en label
      _syncBkTabStatus(lpdUuid, behaald);

      try {
        const resp = await fetch(`/attestering/${leerlingId}/toggle`, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ lpdUuid, behaald }),
        });

        if (!resp.ok) throw new Error('Server fout: ' + resp.status);
        const data = await resp.json();
        if (!data.success) throw new Error(data.error || 'Onbekende fout');

        _herbereken(data.resultaten);
        showToast(behaald ? 'Doel behaald opgeslagen' : 'Doel gemarkeerd als niet behaald', 'ok');

      } catch (err) {
        // Rollback
        checkbox.checked = !behaald;
        if (flatLabel) flatLabel.classList.toggle('behaald', !behaald);
        _syncBkTabStatus(lpdUuid, !behaald);
        showToast('Opslaan mislukt: ' + err.message, 'err');
      }
    }

    // Sync status-icoon + label in de read-only BK-tab
    function _syncBkTabStatus(lpdUuid, behaald) {
      // Zoek het LPD-item in tab-bk (geen checkbox, wél data-lpd-key)
      const bkTab = document.getElementById('tab-bk');
      if (!bkTab) return;
      const lpdItem = bkTab.querySelector(`[data-lpd-key="${lpdUuid}"]`);
      if (!lpdItem) return;

      const icoon = lpdItem.querySelector('span:first-child');
      const label = lpdItem.querySelector('.lpd-label');

      if (icoon) {
        icoon.innerHTML = behaald ? '&#10003;' : '&#9675;';
        icoon.style.color = behaald ? '#059669' : '#CBD5E1';
      }
      if (label) label.classList.toggle('behaald', behaald);
    }

    // Herbereken voortgangsbalken op basis van server-resultaten.
    // Leest LPD-data uit BEIDE tabs (platte lijst + BK-accordion).
    // Omdat de platte lijst in tab-lpd en de accordion in tab-bk
    // dezelfde data-bk-key / data-dpk-key / data-lpd-key dragen,
    // is het voldoende om één van de twee te lezen — we lezen tab-bk
    // (heeft altijd alle items, ook als tab-lpd verborgen is).
    function _herbereken(resultaten) {
      const bkCards = document.querySelectorAll('#tab-bk [data-bk-key]');

      bkCards.forEach(card => {
        const bkKey  = card.dataset.bkKey;
        const dpkEls = card.querySelectorAll('[data-dpk-key]');

        let bkTotaal  = 0;
        let bkBehaald = 0;

        dpkEls.forEach(dpkEl => {
          const dpkKey = dpkEl.dataset.dpkKey;
          const lpdEls = dpkEl.querySelectorAll('[data-lpd-key]');

          let dpkTotaal  = 0;
          let dpkBehaald = 0;

          lpdEls.forEach(lpdEl => {
            const lpdKey    = lpdEl.dataset.lpdKey;
            const isBehaald = resultaten[lpdKey] === true;
            dpkTotaal++;
            if (isBehaald) dpkBehaald++;
          });

          bkTotaal  += dpkTotaal;
          bkBehaald += dpkBehaald;

          const dpkPct = dpkTotaal > 0 ? Math.round((dpkBehaald / dpkTotaal) * 100) : 0;

          const dpkBar = document.querySelector(`[data-dpk-bar="${dpkKey}"]`);
          if (dpkBar) {
            dpkBar.style.width = dpkPct + '%';
            dpkBar.classList.toggle('partial', dpkPct < 100);
          }

          const dpkStats = document.querySelector(`[data-dpk-stats="${dpkKey}"]`);
          if (dpkStats) {
            dpkStats.textContent = `${dpkBehaald}/${dpkTotaal}`;
            dpkStats.style.color = dpkPct === 100 ? '#059669' : '#94A3B8';
          }

          const dpkBadge = document.querySelector(`[data-dpk-badge="${dpkKey}"]`);
          if (dpkBadge) dpkBadge.style.display = dpkPct === 100 ? 'inline' : 'none';
        });

        const bkPct = bkTotaal > 0 ? Math.round((bkBehaald / bkTotaal) * 100) : 0;

        const bkBar = document.querySelector(`[data-bk-bar="${bkKey}"]`);
        if (bkBar) {
          bkBar.style.width = bkPct + '%';
          bkBar.classList.toggle('partial', bkPct < 100);
        }

        const bkStats = document.querySelector(`[data-bk-stats="${bkKey}"]`);
        if (bkStats) {
          bkStats.textContent = `${bkBehaald}/${bkTotaal}`;
          bkStats.style.color = bkPct === 100 ? '#059669' : '#475569';
        }

        const bkBadge = document.querySelector(`[data-bk-badge="${bkKey}"]`);
        if (bkBadge) bkBadge.style.display = bkPct === 100 ? 'inline-flex' : 'none';
      });
    }

    // Toast
    let _toastTimer = null;
    function showToast(tekst, type) {
      const el = document.getElementById('toast');
      el.textContent = tekst;
      el.className   = 'show ' + type;
      clearTimeout(_toastTimer);
      _toastTimer = setTimeout(() => { el.classList.remove('show'); }, 2800);
    }
  </script>

<%- include("../partials/footer") %>
