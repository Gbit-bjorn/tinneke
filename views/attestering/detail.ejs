<%- include('../partials/head', {title: leerling.naam + ' ' + leerling.voornaam + ' — Attestering', activePage: 'klassen'}) %>

  <style>
    /* ── Pagina-specifieke stijlen ── */

    /* Progress bars (override head.ejs kleuren voor deze pagina) */
    .progress-fill { background: #2563EB; }
    .progress-fill.partial { background: #93C5FD; }

    /* LPD behaald state */
    .lpd-label.behaald { text-decoration: line-through; color: #94A3B8; }

    /* Tab navigatie */
    .tab-bar {
      display: flex;
      border-bottom: 2px solid #E2E8F0;
      margin-bottom: 24px;
    }
    .tab-btn {
      padding: 10px 24px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      font-weight: 600;
      border: none;
      border-bottom: 2px solid transparent;
      margin-bottom: -2px;
      background: transparent;
      cursor: pointer;
      white-space: nowrap;
      transition: color 150ms, border-color 150ms;
      color: #94A3B8;
    }
    .tab-btn.actief {
      color: #1E3A8A;
      border-bottom-color: #1E3A8A;
    }
    .tab-btn:hover:not(.actief) { color: #475569; }

    /* Toast (eigen positie onderaan) */
    #toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      padding: 10px 18px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 600;
      opacity: 0;
      pointer-events: none;
      transition: opacity 250ms ease;
      z-index: 9999;
    }
    #toast.show { opacity: 1; }
    #toast.ok  { background: #D1FAE5; color: #065F46; border: 1px solid #6EE7B7; }
    #toast.err { background: #FEE2E2; color: #991B1B; border: 1px solid #FCA5A5; }

    /* Details toggle-icoon animatie */
    details summary .toggle-icon { transition: transform 200ms; display: inline-block; }
    details[open] summary .toggle-icon { transform: rotate(90deg); }

    /* BK summary hover */
    .bk-summary:hover { background: #DBEAFE; }

    /* LPD rij hover */
    .lpd-flat-item:hover { background: #F8FAFC; }

    /* LPD nummer badge */
    .lpd-nr-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 32px;
      min-width: 32px;
      height: 20px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
      background: #DBEAFE;
      color: #1E3A8A;
    }

    /* BK behaald badge */
    .bk-behaald-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: #D1FAE5;
      color: #065F46;
      font-size: 12px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 999px;
      white-space: nowrap;
      margin-right: 8px;
    }

    /* DPK behaald vinkje */
    .dpk-behaald-vink {
      color: #059669;
      font-size: 14px;
      font-weight: 700;
    }
  </style>

  <!-- ── Header ── -->
  <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <div>
      <h1 style="margin-bottom: 4px;">
        <%= leerling.voornaam %> <%= leerling.naam %>
      </h1>
      <p class="text-secondary" style="font-size: 14px;">
        <span style="font-weight: 600; color: #1E3A8A;"><%= klas.naam %></span>
        <% if (klas.richting) { %>
          <span style="margin: 0 8px; color: #CBD5E1;">&middot;</span><%= klas.richting %>
        <% } %>
      </p>
    </div>

    <div class="flex gap-2 flex-wrap">
      <a href="/export/<%= leerling.id %>"
         class="btn btn-secondary btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Export
      </a>
      <a href="/klassen/<%= typeof klasId !== 'undefined' && klasId ? klasId : '' %>"
         class="btn btn-secondary btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Terug naar klas
      </a>
    </div>
  </div>

  <!-- ── Fout-/leeg-states ── -->
  <% if (!leerplanUuid) { %>
    <div class="card" style="padding: 20px; display: flex; align-items: center; gap: 12px; color: #475569; font-size: 14px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#94A3B8" stroke-width="2" style="flex-shrink: 0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span>Geen leerplan gekoppeld aan deze klas. Koppel eerst een leerplan via het klassenbeheer.</span>
    </div>
  <% } else if (typeof llinkidFout !== 'undefined' && llinkidFout) { %>
    <div class="card alert alert-error" style="padding: 20px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#DC2626" stroke-width="2" style="flex-shrink: 0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <span>Fout bij ophalen doelen van LLinkid: <%= llinkidFout %></span>
    </div>
  <% } else if (bkSecties.length === 0) { %>
    <div class="card" style="padding: 20px; display: flex; align-items: center; gap: 12px; color: #475569; font-size: 14px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#94A3B8" stroke-width="2" style="flex-shrink: 0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      <span>Geen doelen gevonden voor dit leerplan.</span>
    </div>
  <% } else { %>

  <!-- ── Tab navigatie ── -->
  <div class="tab-bar">
    <button type="button" id="tab-btn-lpd" onclick="setTab('lpd')" class="tab-btn actief">
      LPD's
    </button>
    <button type="button" id="tab-btn-bk" onclick="setTab('bk')" class="tab-btn">
      BK's
    </button>
  </div>


  <!-- ══════════════════════════════════════════════════ -->
  <!-- TAB 1: Platte LPD-lijst (werkweergave)            -->
  <!-- ══════════════════════════════════════════════════ -->
  <div id="tab-lpd" class="card" style="padding: 20px;">

    <%
      /* Bouw een gesorteerde, platte lijst van alle LPDs op server-side.
         Elk LPD krijgt bk.key + dpk.key mee als data-attributen zodat
         _herbereken() de checkboxes nog steeds kan vinden. */
    %>

    <% bkSecties.forEach(function(bk, bkIdx) { %>

      <!-- BK-groepheader -->
      <div style="<%= bkIdx > 0 ? 'margin-top: 20px; padding-top: 16px; border-top: 1px solid #F1F5F9;' : '' %>
                  display: flex; align-items: center; gap: 8px; margin-bottom: 8px;
                  padding-left: 8px; border-left: 4px solid #1E3A8A;">
        <span style="font-weight: 700; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; color: #1E3A8A;">
          BK: <%= bk.titel || bk.key %>
        </span>
      </div>

      <% bk.dpkSecties.forEach(function(dpk) { %>

        <!-- DPK-subheader — verberg bij synthetische DPK -->
        <% if (!dpk.synthetic && (dpk.titel || dpk.key)) { %>
          <div style="display: flex; align-items: center; gap: 6px; padding: 4px 0 4px 20px; margin-bottom: 4px;">
            <span style="color: #CBD5E1; font-size: 12px;">&#x2514;</span>
            <span style="font-size: 12px; font-weight: 600; color: #94A3B8;"><%= dpk.titel || dpk.key %></span>
          </div>
        <% } %>

        <% dpk.lpds.forEach(function(lpd) { %>
          <div class="lpd-flat-item"
               style="display: flex; align-items: flex-start; gap: 10px; padding: 8px 12px; border-radius: 8px; transition: background 150ms;"
               data-lpd-key="<%= lpd.key %>"
               data-bk-key="<%= bk.key %>"
               data-dpk-key="<%= dpk.key %>">

            <input
              type="checkbox"
              id="lpd-flat-<%= lpd.key %>"
              style="margin-top: 2px; width: 16px; height: 16px; accent-color: #1E3A8A; cursor: pointer; flex-shrink: 0;"
              <%= lpd.behaald ? 'checked' : '' %>
              onchange="toggleLpd(this, '<%= lpd.key %>', '<%= leerling.id %>')"
            />

            <span class="lpd-nr-badge" style="margin-top: 2px;">
              <%= lpd.nr %>
            </span>

            <label
              for="lpd-flat-<%= lpd.key %>"
              class="lpd-label<%= lpd.behaald ? ' behaald' : '' %>"
              style="font-size: 14px; color: #0F172A; line-height: 1.4; cursor: pointer; flex: 1;">
              <%= lpd.titel %>
            </label>

          </div>
        <% }); %>

      <% }); %>

    <% }); %>

  </div><!-- /tab-lpd -->


  <!-- ══════════════════════════════════════════════════ -->
  <!-- TAB 2: BK-overzicht (met checkboxes)             -->
  <!-- ══════════════════════════════════════════════════ -->
  <div id="tab-bk" style="display: none; flex-direction: column; gap: 16px;">

    <% bkSecties.forEach(function(bk) { %>

      <div class="card" style="overflow: hidden;" data-bk-key="<%= bk.key %>">

        <!-- BK details/summary toggle -->
        <details open>
          <summary class="bk-summary"
                   style="display: flex; align-items: center; gap: 12px; padding: 16px 20px;
                          background: #EFF6FF; border-bottom: 1px solid #DBEAFE;
                          cursor: pointer; list-style: none; user-select: none;
                          transition: background 150ms;">
            <span class="toggle-icon" style="color: #1E3A8A; font-size: 12px; flex-shrink: 0;">&#9654;</span>
            <span style="font-weight: 700; font-size: 15px; color: #1E3A8A; flex: 1;">
              BK: <%= bk.titel || bk.key %>
            </span>
            <!-- BK behaald badge -->
            <span
              data-bk-badge="<%= bk.key %>"
              class="bk-behaald-badge"
              style="<%= bk.stats.percentage === 100 ? '' : 'display: none;' %>">
              &#10003; Behaald
            </span>
            <!-- BK voortgang teller -->
            <span
              data-bk-stats="<%= bk.key %>"
              style="font-size: 14px; color: #475569; font-weight: 600; white-space: nowrap; flex-shrink: 0;">
              <%= bk.stats.behaald %>/<%= bk.stats.totaal %>
            </span>
          </summary>

          <!-- BK voortgangsbalk (altijd zichtbaar, net onder summary) -->
          <div style="padding: 8px 20px 4px; background: #EFF6FF; border-bottom: 1px solid #DBEAFE;">
            <div class="progress-track">
              <div
                class="progress-fill<%= bk.stats.percentage < 100 ? ' partial' : '' %>"
                style="width:<%= bk.stats.percentage %>%"
                data-bk-bar="<%= bk.key %>">
              </div>
            </div>
          </div>

          <!-- BK body -->
          <div class="bk-body" style="padding: 20px; display: flex; flex-direction: column; gap: 20px;">

            <% bk.dpkSecties.forEach(function(dpk) { %>
              <div data-dpk-key="<%= dpk.key %>">

                <!-- DPK header — verberg bij synthetische DPK -->
                <% if (!dpk.synthetic) { %>
                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
                  <span style="color: #CBD5E1; font-size: 12px; flex-shrink: 0;">&#x2523;</span>
                  <span style="font-weight: 700; font-size: 14px; color: #0F172A; flex: 1;">
                    DPK: <%= dpk.titel || dpk.key %>
                  </span>
                  <!-- DPK behaald vink -->
                  <span
                    data-dpk-badge="<%= dpk.key %>"
                    class="dpk-behaald-vink"
                    style="<%= dpk.stats.percentage === 100 ? '' : 'display: none;' %>">
                    &#10003;
                  </span>
                  <span
                    data-dpk-stats="<%= dpk.key %>"
                    style="font-size: 12px; font-weight: 600; white-space: nowrap; flex-shrink: 0;
                           color: <%= dpk.stats.percentage === 100 ? '#059669' : '#94A3B8' %>;">
                    <%= dpk.stats.behaald %>/<%= dpk.stats.totaal %>
                  </span>
                </div>

                <!-- DPK voortgangsbalk -->
                <div class="progress-track mb-3" style="margin-left: 16px;">
                  <div
                    class="progress-fill<%= dpk.stats.percentage < 100 ? ' partial' : '' %>"
                    style="width:<%= dpk.stats.percentage %>%"
                    data-dpk-bar="<%= dpk.key %>">
                  </div>
                </div>
                <% } %>

                <!-- LPD regels -->
                <div style="padding-left: 16px; border-left: 2px solid #DBEAFE; display: flex; flex-direction: column; gap: 4px;">
                  <% dpk.lpds.forEach(function(lpd) { %>
                    <div class="lpd-flat-item"
                         style="display: flex; align-items: flex-start; gap: 10px; padding: 8px 12px; border-radius: 8px; transition: background 150ms;"
                         data-lpd-key="<%= lpd.key %>"
                         data-bk-key="<%= bk.key %>"
                         data-dpk-key="<%= dpk.key %>">

                      <input
                        type="checkbox"
                        id="lpd-bk-<%= lpd.key %>"
                        style="margin-top: 2px; width: 16px; height: 16px; accent-color: #1E3A8A; cursor: pointer; flex-shrink: 0;"
                        <%= lpd.behaald ? 'checked' : '' %>
                        onchange="toggleLpd(this, '<%= lpd.key %>', '<%= leerling.id %>')"
                      />

                      <span class="lpd-nr-badge" style="margin-top: 2px;">
                        <%= lpd.nr %>
                      </span>

                      <label
                        for="lpd-bk-<%= lpd.key %>"
                        class="lpd-label<%= lpd.behaald ? ' behaald' : '' %>"
                        style="font-size: 14px; color: #0F172A; line-height: 1.4; cursor: pointer; flex: 1;">
                        <%= lpd.titel %>
                      </label>

                    </div>
                  <% }); %>
                </div>

              </div>
            <% }); %>

          </div><!-- /bk-body -->
        </details>

      </div><!-- /card -->

    <% }); %>

  </div><!-- /tab-bk -->

  <% } %>

  <!-- Toast -->
  <div id="toast" role="status" aria-live="polite"></div>

  <script>
    // ── Tab-switching ──
    function setTab(naam) {
      var tabLpd = document.getElementById('tab-lpd');
      var tabBk  = document.getElementById('tab-bk');
      var btnLpd = document.getElementById('tab-btn-lpd');
      var btnBk  = document.getElementById('tab-btn-bk');

      if (naam === 'lpd') {
        tabLpd.style.display = '';
        tabBk.style.display  = 'none';
        btnLpd.classList.add('actief');
        btnBk.classList.remove('actief');
      } else {
        tabLpd.style.display = 'none';
        tabBk.style.display  = 'flex';
        btnLpd.classList.remove('actief');
        btnBk.classList.add('actief');
      }
    }

    // AJAX toggle LPD
    async function toggleLpd(checkbox, lpdUuid, leerlingId) {
      const behaald = checkbox.checked;

      // Optimistisch UI — sync beide tabs
      const andereId = checkbox.id.startsWith('lpd-flat-')
        ? 'lpd-bk-'   + lpdUuid
        : 'lpd-flat-' + lpdUuid;
      const andereCheckbox = document.getElementById(andereId);
      if (andereCheckbox) andereCheckbox.checked = behaald;

      // Labels in beide tabs bijwerken
      document.querySelectorAll(`label[for="lpd-flat-${lpdUuid}"], label[for="lpd-bk-${lpdUuid}"]`)
        .forEach(lbl => lbl.classList.toggle('behaald', behaald));

      try {
        const resp = await fetch(`/attestering/${leerlingId}/toggle`, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ lpdUuid, behaald }),
        });

        if (!resp.ok) throw new Error('Server fout: ' + resp.status);
        const data = await resp.json();
        if (!data.success) throw new Error(data.error || 'Onbekende fout');

        _herbereken(data.resultaten);
        showToast(behaald ? 'Doel behaald opgeslagen' : 'Doel gemarkeerd als niet behaald', 'ok');

      } catch (err) {
        // Rollback
        checkbox.checked = !behaald;
        if (andereCheckbox) andereCheckbox.checked = !behaald;
        document.querySelectorAll(`label[for="lpd-flat-${lpdUuid}"], label[for="lpd-bk-${lpdUuid}"]`)
          .forEach(lbl => lbl.classList.toggle('behaald', !behaald));
        showToast('Opslaan mislukt: ' + err.message, 'err');
      }
    }

    // Herbereken voortgangsbalken op basis van server-resultaten.
    // Leest LPD-data uit BEIDE tabs (platte lijst + BK-accordion).
    // Omdat de platte lijst in tab-lpd en de accordion in tab-bk
    // dezelfde data-bk-key / data-dpk-key / data-lpd-key dragen,
    // is het voldoende om één van de twee te lezen — we lezen tab-bk
    // (heeft altijd alle items, ook als tab-lpd verborgen is).
    function _herbereken(resultaten) {
      const bkCards = document.querySelectorAll('#tab-bk [data-bk-key]');

      bkCards.forEach(card => {
        const bkKey  = card.dataset.bkKey;
        const dpkEls = card.querySelectorAll('[data-dpk-key]');

        let bkTotaal  = 0;
        let bkBehaald = 0;

        dpkEls.forEach(dpkEl => {
          const dpkKey = dpkEl.dataset.dpkKey;
          const lpdEls = dpkEl.querySelectorAll('[data-lpd-key]');

          let dpkTotaal  = 0;
          let dpkBehaald = 0;

          lpdEls.forEach(lpdEl => {
            const lpdKey    = lpdEl.dataset.lpdKey;
            const isBehaald = resultaten[lpdKey] === true;
            dpkTotaal++;
            if (isBehaald) dpkBehaald++;
          });

          bkTotaal  += dpkTotaal;
          bkBehaald += dpkBehaald;

          const dpkPct = dpkTotaal > 0 ? Math.round((dpkBehaald / dpkTotaal) * 100) : 0;

          const dpkBar = document.querySelector(`[data-dpk-bar="${dpkKey}"]`);
          if (dpkBar) {
            dpkBar.style.width = dpkPct + '%';
            dpkBar.classList.toggle('partial', dpkPct < 100);
          }

          const dpkStats = document.querySelector(`[data-dpk-stats="${dpkKey}"]`);
          if (dpkStats) {
            dpkStats.textContent = `${dpkBehaald}/${dpkTotaal}`;
            dpkStats.style.color = dpkPct === 100 ? '#059669' : '#94A3B8';
          }

          const dpkBadge = document.querySelector(`[data-dpk-badge="${dpkKey}"]`);
          if (dpkBadge) {
            dpkBadge.style.display = dpkPct === 100 ? '' : 'none';
          }
        });

        const bkPct = bkTotaal > 0 ? Math.round((bkBehaald / bkTotaal) * 100) : 0;

        const bkBar = document.querySelector(`[data-bk-bar="${bkKey}"]`);
        if (bkBar) {
          bkBar.style.width = bkPct + '%';
          bkBar.classList.toggle('partial', bkPct < 100);
        }

        const bkStats = document.querySelector(`[data-bk-stats="${bkKey}"]`);
        if (bkStats) {
          bkStats.textContent = `${bkBehaald}/${bkTotaal}`;
          bkStats.style.color = bkPct === 100 ? '#059669' : '#64748B';
        }

        const bkBadge = document.querySelector(`[data-bk-badge="${bkKey}"]`);
        if (bkBadge) {
          bkBadge.style.display = bkPct === 100 ? 'inline-flex' : 'none';
        }
      });
    }

    // Toast
    let _toastTimer = null;
    function showToast(tekst, type) {
      const el = document.getElementById('toast');
      el.textContent = tekst;
      el.className   = 'show ' + type;
      clearTimeout(_toastTimer);
      _toastTimer = setTimeout(() => { el.classList.remove('show'); }, 2800);
    }
  </script>

<%- include("../partials/footer") %>
