<%- include('../partials/head', {title: leerling.naam + ' ' + leerling.voornaam + ' — Attestering', activePage: 'klassen'}) %>

  <style>
    /* Progress bars */
    .progress-track { background: #E2E8F0; border-radius: 999px; height: 5px; overflow: hidden; }
    .progress-fill  { background: #2563EB; height: 100%; border-radius: 999px; transition: width 300ms ease; }
    .progress-fill.partial { background: #93C5FD; }

    /* LPD behaald state */
    .lpd-label.behaald { text-decoration: line-through; color: #94A3B8; }

    /* Toast */
    #toast {
      position: fixed;
      bottom: 24px;
      right: 24px;
      padding: 10px 18px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 600;
      opacity: 0;
      pointer-events: none;
      transition: opacity 250ms ease;
      z-index: 9999;
    }
    #toast.show { opacity: 1; }
    #toast.ok  { background: #D1FAE5; color: #065F46; border: 1px solid #6EE7B7; }
    #toast.err { background: #FEE2E2; color: #991B1B; border: 1px solid #FCA5A5; }

    /* Details toggle-icoon animatie */
    details summary .toggle-icon { transition: transform 200ms; display: inline-block; }
    details[open] summary .toggle-icon { transform: rotate(90deg); }
  </style>

  <!-- ── Header ── -->
  <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
    <div>
      <h1 class="font-heading text-3xl font-bold text-textmain mb-1">
        <%= leerling.voornaam %> <%= leerling.naam %>
      </h1>
      <p class="text-sm text-slate-500">
        <span class="font-semibold text-primary"><%= klas.naam %></span>
        <% if (klas.richting) { %>
          <span class="mx-2 text-slate-300">&middot;</span><%= klas.richting %>
        <% } %>
      </p>
    </div>

    <div class="flex gap-2 flex-wrap">
      <a href="/export/<%= leerling.id %>"
         class="clay-btn inline-flex items-center gap-2 px-4 py-2 bg-white border border-blue-100 text-primary text-sm font-semibold rounded-xl hover:bg-blue-50 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        Export
      </a>
      <a href="/klassen/<%= typeof klasId !== 'undefined' && klasId ? klasId : '' %>"
         class="clay-btn inline-flex items-center gap-2 px-4 py-2 bg-white border border-blue-100 text-slate-500 text-sm font-semibold rounded-xl hover:bg-slate-50 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Terug naar klas
      </a>
    </div>
  </div>

  <!-- ── Fout-/leeg-states ── -->
  <% if (!leerplanUuid) { %>
    <div class="clay-card p-5 flex items-center gap-3 text-slate-500 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#94A3B8" stroke-width="2" class="shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span>Geen leerplan gekoppeld aan deze klas. Koppel eerst een leerplan via het klassenbeheer.</span>
    </div>
  <% } else if (typeof llinkidFout !== 'undefined' && llinkidFout) { %>
    <div class="clay-card p-5 flex items-center gap-3 bg-red-50 text-red-700 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#DC2626" stroke-width="2" class="shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
      </svg>
      <span>Fout bij ophalen doelen van LLinkid: <%= llinkidFout %></span>
    </div>
  <% } else if (bkSecties.length === 0) { %>
    <div class="clay-card p-5 flex items-center gap-3 text-slate-500 text-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#94A3B8" stroke-width="2" class="shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
      </svg>
      <span>Geen doelen gevonden voor dit leerplan.</span>
    </div>
  <% } else { %>

  <!-- ── Tab navigatie ── -->
  <div class="flex gap-0 border-b-2 border-slate-200 mb-6">
    <button type="button" id="tab-btn-lpd" onclick="setTab('lpd')"
      class="px-6 py-2.5 font-heading font-semibold text-sm border-b-2 -mb-[2px] transition-colors whitespace-nowrap
             text-primary border-primary">
      LPD's
    </button>
    <button type="button" id="tab-btn-bk" onclick="setTab('bk')"
      class="px-6 py-2.5 font-heading font-semibold text-sm border-b-2 -mb-[2px] transition-colors whitespace-nowrap
             text-slate-400 border-transparent hover:text-slate-600">
      BK's
    </button>
  </div>


  <!-- ══════════════════════════════════════════════════ -->
  <!-- TAB 1: Platte LPD-lijst (werkweergave)            -->
  <!-- ══════════════════════════════════════════════════ -->
  <div id="tab-lpd" class="clay-card p-5">

    <%
      /* Bouw een gesorteerde, platte lijst van alle LPDs op server-side.
         Elk LPD krijgt bk.key + dpk.key mee als data-attributen zodat
         _herbereken() de checkboxes nog steeds kan vinden. */
    %>

    <% bkSecties.forEach(function(bk, bkIdx) { %>

      <!-- BK-groepheader -->
      <div class="<%= bkIdx > 0 ? 'mt-5 pt-4 border-t border-slate-100' : '' %>
                  flex items-center gap-2 mb-2 pl-2 border-l-4 border-primary">
        <span class="font-heading font-semibold text-sm uppercase tracking-wide text-primary">
          BK: <%= bk.titel || bk.key %>
        </span>
      </div>

      <% bk.dpkSecties.forEach(function(dpk) { %>

        <!-- DPK-subheader — verberg bij synthetische DPK -->
        <% if (!dpk.synthetic && (dpk.titel || dpk.key)) { %>
          <div class="flex items-center gap-1.5 py-1 pl-5 mb-1">
            <span class="text-slate-300 text-xs">&#x2514;</span>
            <span class="text-xs font-semibold text-slate-400"><%= dpk.titel || dpk.key %></span>
          </div>
        <% } %>

        <% dpk.lpds.forEach(function(lpd) { %>
          <div class="lpd-flat-item flex items-start gap-2.5 px-3 py-2 rounded-xl hover:bg-slate-50 transition-colors"
               data-lpd-key="<%= lpd.key %>"
               data-bk-key="<%= bk.key %>"
               data-dpk-key="<%= dpk.key %>">

            <input
              type="checkbox"
              id="lpd-flat-<%= lpd.key %>"
              class="mt-0.5 w-4 h-4 accent-primary cursor-pointer shrink-0"
              <%= lpd.behaald ? 'checked' : '' %>
              onchange="toggleLpd(this, '<%= lpd.key %>', '<%= leerling.id %>')"
            />

            <span class="inline-flex items-center justify-center w-8 h-5 rounded-full text-xs font-semibold bg-blue-100 text-primary shrink-0 mt-0.5">
              <%= lpd.nr %>
            </span>

            <label
              for="lpd-flat-<%= lpd.key %>"
              class="lpd-label<%= lpd.behaald ? ' behaald' : '' %> text-sm text-textmain leading-snug cursor-pointer flex-1">
              <%= lpd.titel %>
            </label>

          </div>
        <% }); %>

      <% }); %>

    <% }); %>

  </div><!-- /tab-lpd -->


  <!-- ══════════════════════════════════════════════════ -->
  <!-- TAB 2: BK-overzicht (met checkboxes)             -->
  <!-- ══════════════════════════════════════════════════ -->
  <div id="tab-bk" style="display:none;" class="flex flex-col gap-4">

    <% bkSecties.forEach(function(bk) { %>

      <div class="clay-card overflow-hidden" data-bk-key="<%= bk.key %>">

        <!-- BK details/summary toggle -->
        <details open>
          <summary class="flex items-center gap-3 px-5 py-4 bg-blue-50 border-b border-blue-100 cursor-pointer list-none hover:bg-blue-100 transition-colors select-none">
            <span class="toggle-icon text-primary text-xs shrink-0">&#9654;</span>
            <span class="font-heading font-semibold text-base text-primary flex-1">
              BK: <%= bk.titel || bk.key %>
            </span>
            <!-- BK behaald badge -->
            <span
              data-bk-badge="<%= bk.key %>"
              class="<%= bk.stats.percentage === 100 ? 'inline-flex' : 'hidden' %> items-center gap-1 bg-emerald-100 text-emerald-700 text-xs font-bold px-2.5 py-1 rounded-full whitespace-nowrap mr-2">
              &#10003; Behaald
            </span>
            <!-- BK voortgang teller -->
            <span
              data-bk-stats="<%= bk.key %>"
              class="text-sm text-slate-500 font-semibold whitespace-nowrap shrink-0">
              <%= bk.stats.behaald %>/<%= bk.stats.totaal %>
            </span>
          </summary>

          <!-- BK voortgangsbalk (altijd zichtbaar, net onder summary) -->
          <div class="px-5 pt-2 pb-1 bg-blue-50 border-b border-blue-100">
            <div class="progress-track">
              <div
                class="progress-fill<%= bk.stats.percentage < 100 ? ' partial' : '' %>"
                style="width:<%= bk.stats.percentage %>%"
                data-bk-bar="<%= bk.key %>">
              </div>
            </div>
          </div>

          <!-- BK body -->
          <div class="bk-body p-5 flex flex-col gap-5">

            <% bk.dpkSecties.forEach(function(dpk) { %>
              <div data-dpk-key="<%= dpk.key %>">

                <!-- DPK header — verberg bij synthetische DPK -->
                <% if (!dpk.synthetic) { %>
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-slate-300 text-xs shrink-0">&#x2523;</span>
                  <span class="font-heading font-semibold text-sm text-textmain flex-1">
                    DPK: <%= dpk.titel || dpk.key %>
                  </span>
                  <!-- DPK behaald vink -->
                  <span
                    data-dpk-badge="<%= dpk.key %>"
                    class="<%= dpk.stats.percentage === 100 ? 'inline' : 'hidden' %> text-emerald-600 text-sm font-bold">
                    &#10003;
                  </span>
                  <span
                    data-dpk-stats="<%= dpk.key %>"
                    class="text-xs font-semibold whitespace-nowrap shrink-0 <%= dpk.stats.percentage === 100 ? 'text-emerald-600' : 'text-slate-400' %>">
                    <%= dpk.stats.behaald %>/<%= dpk.stats.totaal %>
                  </span>
                </div>

                <!-- DPK voortgangsbalk -->
                <div class="progress-track mb-3 ml-4">
                  <div
                    class="progress-fill<%= dpk.stats.percentage < 100 ? ' partial' : '' %>"
                    style="width:<%= dpk.stats.percentage %>%"
                    data-dpk-bar="<%= dpk.key %>">
                  </div>
                </div>
                <% } %>

                <!-- LPD regels -->
                <div class="pl-4 border-l-2 border-blue-100 flex flex-col gap-1">
                  <% dpk.lpds.forEach(function(lpd) { %>
                    <div class="lpd-flat-item flex items-start gap-2.5 px-3 py-2 rounded-xl hover:bg-slate-50 transition-colors"
                         data-lpd-key="<%= lpd.key %>"
                         data-bk-key="<%= bk.key %>"
                         data-dpk-key="<%= dpk.key %>">

                      <input
                        type="checkbox"
                        id="lpd-bk-<%= lpd.key %>"
                        class="mt-0.5 w-4 h-4 accent-primary cursor-pointer shrink-0"
                        <%= lpd.behaald ? 'checked' : '' %>
                        onchange="toggleLpd(this, '<%= lpd.key %>', '<%= leerling.id %>')"
                      />

                      <span class="inline-flex items-center justify-center w-8 h-5 rounded-full text-xs font-semibold bg-blue-100 text-primary shrink-0 mt-0.5">
                        <%= lpd.nr %>
                      </span>

                      <label
                        for="lpd-bk-<%= lpd.key %>"
                        class="lpd-label<%= lpd.behaald ? ' behaald' : '' %> text-sm text-textmain leading-snug cursor-pointer flex-1">
                        <%= lpd.titel %>
                      </label>

                    </div>
                  <% }); %>
                </div>

              </div>
            <% }); %>

          </div><!-- /bk-body -->
        </details>

      </div><!-- /clay-card -->

    <% }); %>

  </div><!-- /tab-bk -->

  <% } %>

  <!-- Toast -->
  <div id="toast" role="status" aria-live="polite"></div>

  <script>
    // ── Tab-switching ──
    function setTab(naam) {
      var tabLpd = document.getElementById('tab-lpd');
      var tabBk  = document.getElementById('tab-bk');
      var btnLpd = document.getElementById('tab-btn-lpd');
      var btnBk  = document.getElementById('tab-btn-bk');

      if (naam === 'lpd') {
        tabLpd.style.display = '';
        tabBk.style.display  = 'none';
        btnLpd.className = btnLpd.className
          .replace('text-slate-400 border-transparent hover:text-slate-600', '')
          + ' text-primary border-primary';
        btnBk.className = btnBk.className
          .replace('text-primary border-primary', '')
          + ' text-slate-400 border-transparent hover:text-slate-600';
      } else {
        tabLpd.style.display = 'none';
        tabBk.style.display  = 'flex';
        btnLpd.className = btnLpd.className
          .replace('text-primary border-primary', '')
          + ' text-slate-400 border-transparent hover:text-slate-600';
        btnBk.className = btnBk.className
          .replace('text-slate-400 border-transparent hover:text-slate-600', '')
          + ' text-primary border-primary';
      }
    }

    // AJAX toggle LPD
    async function toggleLpd(checkbox, lpdUuid, leerlingId) {
      const behaald = checkbox.checked;

      // Optimistisch UI — sync beide tabs
      const andereId = checkbox.id.startsWith('lpd-flat-')
        ? 'lpd-bk-'   + lpdUuid
        : 'lpd-flat-' + lpdUuid;
      const andereCheckbox = document.getElementById(andereId);
      if (andereCheckbox) andereCheckbox.checked = behaald;

      // Labels in beide tabs bijwerken
      document.querySelectorAll(`label[for="lpd-flat-${lpdUuid}"], label[for="lpd-bk-${lpdUuid}"]`)
        .forEach(lbl => lbl.classList.toggle('behaald', behaald));

      try {
        const resp = await fetch(`/attestering/${leerlingId}/toggle`, {
          method:  'POST',
          headers: { 'Content-Type': 'application/json' },
          body:    JSON.stringify({ lpdUuid, behaald }),
        });

        if (!resp.ok) throw new Error('Server fout: ' + resp.status);
        const data = await resp.json();
        if (!data.success) throw new Error(data.error || 'Onbekende fout');

        _herbereken(data.resultaten);
        showToast(behaald ? 'Doel behaald opgeslagen' : 'Doel gemarkeerd als niet behaald', 'ok');

      } catch (err) {
        // Rollback
        checkbox.checked = !behaald;
        if (andereCheckbox) andereCheckbox.checked = !behaald;
        document.querySelectorAll(`label[for="lpd-flat-${lpdUuid}"], label[for="lpd-bk-${lpdUuid}"]`)
          .forEach(lbl => lbl.classList.toggle('behaald', !behaald));
        showToast('Opslaan mislukt: ' + err.message, 'err');
      }
    }

    // Herbereken voortgangsbalken op basis van server-resultaten.
    // Leest LPD-data uit BEIDE tabs (platte lijst + BK-accordion).
    // Omdat de platte lijst in tab-lpd en de accordion in tab-bk
    // dezelfde data-bk-key / data-dpk-key / data-lpd-key dragen,
    // is het voldoende om één van de twee te lezen — we lezen tab-bk
    // (heeft altijd alle items, ook als tab-lpd verborgen is).
    function _herbereken(resultaten) {
      const bkCards = document.querySelectorAll('#tab-bk [data-bk-key]');

      bkCards.forEach(card => {
        const bkKey  = card.dataset.bkKey;
        const dpkEls = card.querySelectorAll('[data-dpk-key]');

        let bkTotaal  = 0;
        let bkBehaald = 0;

        dpkEls.forEach(dpkEl => {
          const dpkKey = dpkEl.dataset.dpkKey;
          const lpdEls = dpkEl.querySelectorAll('[data-lpd-key]');

          let dpkTotaal  = 0;
          let dpkBehaald = 0;

          lpdEls.forEach(lpdEl => {
            const lpdKey    = lpdEl.dataset.lpdKey;
            const isBehaald = resultaten[lpdKey] === true;
            dpkTotaal++;
            if (isBehaald) dpkBehaald++;
          });

          bkTotaal  += dpkTotaal;
          bkBehaald += dpkBehaald;

          const dpkPct = dpkTotaal > 0 ? Math.round((dpkBehaald / dpkTotaal) * 100) : 0;

          const dpkBar = document.querySelector(`[data-dpk-bar="${dpkKey}"]`);
          if (dpkBar) {
            dpkBar.style.width = dpkPct + '%';
            dpkBar.classList.toggle('partial', dpkPct < 100);
          }

          const dpkStats = document.querySelector(`[data-dpk-stats="${dpkKey}"]`);
          if (dpkStats) {
            dpkStats.textContent = `${dpkBehaald}/${dpkTotaal}`;
            dpkStats.style.color = dpkPct === 100 ? '#059669' : '#94A3B8';
          }

          const dpkBadge = document.querySelector(`[data-dpk-badge="${dpkKey}"]`);
          if (dpkBadge) {
            dpkBadge.classList.toggle('hidden',  dpkPct !== 100);
            dpkBadge.classList.toggle('inline',  dpkPct === 100);
          }
        });

        const bkPct = bkTotaal > 0 ? Math.round((bkBehaald / bkTotaal) * 100) : 0;

        const bkBar = document.querySelector(`[data-bk-bar="${bkKey}"]`);
        if (bkBar) {
          bkBar.style.width = bkPct + '%';
          bkBar.classList.toggle('partial', bkPct < 100);
        }

        const bkStats = document.querySelector(`[data-bk-stats="${bkKey}"]`);
        if (bkStats) {
          bkStats.textContent = `${bkBehaald}/${bkTotaal}`;
          bkStats.style.color = bkPct === 100 ? '#059669' : '#64748B';
        }

        const bkBadge = document.querySelector(`[data-bk-badge="${bkKey}"]`);
        if (bkBadge) {
          bkBadge.classList.toggle('hidden',       bkPct !== 100);
          bkBadge.classList.toggle('inline-flex',  bkPct === 100);
        }
      });
    }

    // Toast
    let _toastTimer = null;
    function showToast(tekst, type) {
      const el = document.getElementById('toast');
      el.textContent = tekst;
      el.className   = 'show ' + type;
      clearTimeout(_toastTimer);
      _toastTimer = setTimeout(() => { el.classList.remove('show'); }, 2800);
    }
  </script>

<%- include("../partials/footer") %>
