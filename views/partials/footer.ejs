</main>

<footer style="margin-top:48px; padding:20px 0; border-top:1px solid #E2E8F0;">
  <div style="max-width:1200px; margin:0 auto; padding:0 16px; display:flex; align-items:center; justify-content:space-between;">
    <span style="font-size:13px; color:#94A3B8;"><%= appNaam %> &mdash; <%= schoolNaam %></span>
    <span style="font-size:13px; color:#94A3B8;">&copy; <%= new Date().getFullYear() %></span>
  </div>
</footer>

<!-- ── Toast auto-dismiss ── -->
<script>
  (function () {
    setTimeout(function () {
      document.querySelectorAll('.toast').forEach(function (t) {
        t.style.animation = 'slideOut 250ms ease-in forwards';
        setTimeout(function () { t.remove(); }, 250);
      });
    }, 4000);
  })();
</script>

</body>
</html>
