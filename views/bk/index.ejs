<%- include('../partials/head', { title: 'Beroepskwalificaties', activePage: 'bk', flash: flash || {} }) %>

  <!-- Paginaheader -->
  <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:12px; margin-bottom:24px;">
    <div>
      <h1 style="font-size:26px; font-weight:700; color:#0F172A; margin:0 0 4px 0;">Beroepskwalificaties</h1>
      <p style="font-size:14px; color:#475569; margin:0;">
        Overzicht van alle BK's met gekoppelde richtingen
      </p>
    </div>
    <% if (typeof user !== 'undefined' && (user.rol === 'admin' || user.rol === 'superadmin')) { %>
    <form action="/bk/sync" method="POST" style="margin:0;">
      <button type="submit" class="btn btn-primary" style="min-height:44px; gap:8px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        Sync vanuit mapping
      </button>
    </form>
    <% } %>
  </div>

  <!-- Zoek- en filterbalk -->
  <div class="card" style="padding:16px; margin-bottom:20px; display:flex; flex-wrap:wrap; gap:12px; align-items:center;">
    <div style="flex:1; min-width:240px; position:relative;">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#94A3B8"
           style="position:absolute; left:12px; top:50%; transform:translateY(-50%); pointer-events:none; z-index:1;">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z" />
      </svg>
      <input
        id="zoek-input"
        type="search"
        placeholder="Zoek op code of naam&hellip;"
        class="input"
        style="padding-left:36px;"
        autocomplete="off"
      />
    </div>
    <div style="min-width:180px;">
      <select id="niveau-filter" class="input">
        <option value="">Alle niveaus</option>
        <option value="2">Niveau 2</option>
        <option value="3">Niveau 3</option>
        <option value="4">Niveau 4</option>
        <option value="5">Niveau 5</option>
      </select>
    </div>
  </div>

  <!-- Teller -->
  <p style="font-size:0.875rem; color:#94A3B8; margin-bottom:16px;">
    <strong id="bk-teller" style="color:#0F172A; font-weight:600;"><%= bks.length %></strong>
    BK<span id="bk-teller-suffix"><%= bks.length !== 1 ? "'s" : '' %></span> gevonden
  </p>

  <!-- Grid van BK-kaarten -->
  <div id="bk-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(300px, 1fr)); gap:16px;">
    <% bks.forEach(function(bk) { %>
    <a href="/bk/<%= bk.id %>"
       class="card card-hover bk-kaart"
       style="padding:20px; display:flex; flex-direction:column; gap:0; text-decoration:none; color:inherit;"
       data-naam="<%= (bk.naam || '').toLowerCase() %>"
       data-code="<%= (bk.code || '').toLowerCase() %>"
       data-niveau="<%= bk.vks_niveau || '' %>">

      <!-- Kaarthoofding -->
      <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px; gap:8px;">
        <div style="min-width:0; flex:1;">
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; flex-wrap:wrap;">
            <span style="font-family:monospace; font-size:13px; font-weight:700; color:#1E3A8A; background:#EFF6FF; border-radius:6px; padding:2px 8px; white-space:nowrap;">
              <%= bk.code || '—' %>
            </span>
            <% if (bk.vks_niveau) { %>
            <span class="badge badge-<%= bk.vks_niveau >= 4 ? 'blue' : bk.vks_niveau >= 3 ? 'orange' : 'gray' %>">
              VKS <%= bk.vks_niveau %>
            </span>
            <% } %>
          </div>
          <h2 style="font-size:15px; font-weight:600; color:#0F172A; margin:0; line-height:1.4;">
            <%= bk.naam || 'Naamloze BK' %>
          </h2>
        </div>
      </div>

      <!-- Statistieken -->
      <div style="display:flex; align-items:center; gap:16px; font-size:13px; color:#64748B; margin-bottom:16px; flex-wrap:wrap;">
        <div style="display:flex; align-items:center; gap:5px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="#1E3A8A" stroke-width="2" style="flex-shrink:0;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          <span>
            <strong style="color:#0F172A;"><%= bk.aantal_dpks || 0 %></strong>
            DBK<%= (bk.aantal_dpks || 0) !== 1 ? "'s" : '' %>
          </span>
        </div>
        <div style="display:flex; align-items:center; gap:5px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="#1E3A8A" stroke-width="2" style="flex-shrink:0;">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
          </svg>
          <span>
            <strong style="color:#0F172A;"><%= bk.aantal_richtingen || 0 %></strong>
            richting<%= (bk.aantal_richtingen || 0) !== 1 ? 'en' : '' %>
          </span>
        </div>
      </div>

      <!-- Actie -->
      <div style="margin-top:auto; display:flex; align-items:center; justify-content:space-between; padding-top:12px; border-top:1px solid #F1F5F9;">
        <span style="font-size:0.75rem; color:#94A3B8;">Bekijk details</span>
        <svg width="14" height="14" fill="none" stroke="#CBD5E1" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </div>

    </a>
    <% }) %>
  </div>

  <!-- Lege staat -->
  <% if (bks.length === 0) { %>
  <div class="card" style="padding:56px 32px; text-align:center; margin-top:8px;">
    <div style="width:64px; height:64px; background:#EFF6FF; border-radius:12px; display:flex; align-items:center; justify-content:center; margin:0 auto 20px auto;">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#1E3A8A" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    </div>
    <h2 style="font-size:20px; font-weight:700; color:#0F172A; margin:0 0 8px 0;">Nog geen beroepskwalificaties</h2>
    <p style="font-size:14px; color:#475569; margin:0 0 24px 0; max-width:360px; margin-left:auto; margin-right:auto;">
      Importeer BK's via de mapping-bestanden of sync vanuit het configuratiebestand.
    </p>
    <% if (typeof user !== 'undefined' && (user.rol === 'admin' || user.rol === 'superadmin')) { %>
    <form action="/bk/sync" method="POST" style="margin:0; display:inline-block;">
      <button type="submit" class="btn btn-primary" style="gap:8px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        Sync vanuit mapping
      </button>
    </form>
    <% } %>
  </div>
  <% } %>

  <!-- Geen resultaten na filteren -->
  <div id="geen-resultaten" class="card" style="padding:48px 24px; text-align:center; display:none; margin-top:16px;">
    <div style="width:48px; height:48px; background:#F1F5F9; border-radius:10px; display:flex; align-items:center; justify-content:center; margin:0 auto 16px auto;">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#94A3B8" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z" />
      </svg>
    </div>
    <h3 style="font-size:17px; font-weight:600; color:#0F172A; margin:0 0 6px 0;">Geen BK's gevonden</h3>
    <p style="font-size:13px; color:#475569; margin:0;">Pas de zoekterm of het niveaufilter aan.</p>
  </div>

<script>
(function () {
  const zoekInput    = document.getElementById('zoek-input');
  const niveauSelect = document.getElementById('niveau-filter');
  const grid         = document.getElementById('bk-grid');
  const geenRes      = document.getElementById('geen-resultaten');
  const teller       = document.getElementById('bk-teller');
  const tellerSuffix = document.getElementById('bk-teller-suffix');

  if (!grid) return;

  function filterBks() {
    const zoekterm = (zoekInput ? zoekInput.value.trim().toLowerCase() : '');
    const niveau   = (niveauSelect ? niveauSelect.value : '');
    const kaarten  = grid.querySelectorAll('.bk-kaart');
    let zichtbaar  = 0;

    kaarten.forEach(function (kaart) {
      const naam   = kaart.dataset.naam  || '';
      const code   = kaart.dataset.code  || '';
      const niv    = kaart.dataset.niveau || '';

      const matchZoek   = !zoekterm || naam.includes(zoekterm) || code.includes(zoekterm);
      const matchNiveau = !niveau   || niv === niveau;

      if (matchZoek && matchNiveau) {
        kaart.style.display = '';
        zichtbaar++;
      } else {
        kaart.style.display = 'none';
      }
    });

    if (geenRes)      geenRes.style.display = zichtbaar > 0 ? 'none' : 'block';
    if (teller)       teller.textContent = zichtbaar;
    if (tellerSuffix) tellerSuffix.textContent = zichtbaar !== 1 ? "'s" : '';
  }

  if (zoekInput)    zoekInput.addEventListener('input', filterBks);
  if (niveauSelect) niveauSelect.addEventListener('change', filterBks);
})();
</script>

<%- include('../partials/footer') %>
