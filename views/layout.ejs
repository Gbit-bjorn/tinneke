<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Tinneke</title>

  <!-- Tailwind CSS via CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary:   '#2563EB',
            bgpage:    '#F8FAFC',
            textmain:  '#1E293B',
            cta:       '#F97316',
          },
          fontFamily: {
            heading: ['Fredoka', 'sans-serif'],
            body:    ['Nunito', 'sans-serif'],
          },
          borderRadius: {
            clay: '20px',
          },
        },
      },
    };
  </script>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">

  <style>
    body { font-family: 'Nunito', sans-serif; background-color: #F8FAFC; color: #1E293B; }
    h1, h2, h3, h4 { font-family: 'Fredoka', sans-serif; }
    .clay-card {
      background: white;
      border-radius: 20px;
      box-shadow: 4px 4px 0px 0px rgba(37,99,235,0.15), 0 2px 16px rgba(37,99,235,0.08);
      border: 1.5px solid rgba(37,99,235,0.10);
    }
    .clay-btn {
      border-radius: 14px;
      box-shadow: 3px 3px 0px 0px rgba(37,99,235,0.20);
      transition: box-shadow 0.15s, transform 0.15s;
    }
    .clay-btn:active { box-shadow: 1px 1px 0px 0px rgba(37,99,235,0.20); transform: translateY(2px); }
    .clay-btn-cta {
      border-radius: 14px;
      box-shadow: 3px 3px 0px 0px rgba(249,115,22,0.25);
      transition: box-shadow 0.15s, transform 0.15s;
    }
    .clay-btn-cta:active { box-shadow: 1px 1px 0px 0px rgba(249,115,22,0.25); transform: translateY(2px); }
  </style>
</head>
<body class="min-h-screen bg-bgpage">

  <!-- Navigatie -->
  <nav class="bg-white shadow-sm border-b border-blue-100 px-6 py-3 flex items-center gap-6">
    <a href="/klassen" class="font-heading text-xl font-bold text-primary tracking-wide">Tinneke</a>
    <div class="flex gap-4 text-sm font-semibold">
      <a href="/klassen"    class="text-textmain hover:text-primary transition-colors">Klassen</a>
      <a href="/llinkid"   class="text-textmain hover:text-primary transition-colors">LLinkid</a>
      <a href="/attestering" class="text-textmain hover:text-primary transition-colors">Attestering</a>
      <a href="/export"    class="text-textmain hover:text-primary transition-colors">Export</a>
    </div>
    <div class="ml-auto">
      <a href="/auth/logout" class="text-sm text-slate-400 hover:text-red-500 transition-colors">Afmelden</a>
    </div>
  </nav>

  <!-- Pagina-inhoud -->
  <main class="max-w-6xl mx-auto px-4 py-8">
    <%- body %>
  </main>

</body>
</html>
