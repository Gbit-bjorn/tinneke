<%- include('../partials/head', {title: 'LLinkid Leerplannen', activePage: 'llinkid', flash: {}}) %>

  <!-- Paginatitel -->
  <div style="margin-bottom:20px;">
    <h1 style="font-size:1.75rem; font-weight:700; color:#0F172A; letter-spacing:-0.3px; margin-bottom:4px;">LLinkid Leerplannen</h1>
    <p style="font-size:0.875rem; color:#475569;">Zoek en bekijk officiële leerplannen van KOV</p>
  </div>

  <!-- Zoekbalk -->
  <form method="GET" action="/llinkid" style="display:flex; gap:8px; margin-bottom:20px; flex-wrap:wrap;">
    <div style="flex:1; min-width:200px; position:relative;">
      <input
        type="text"
        id="llinkid-zoek"
        name="q"
        value="<%= zoekterm %>"
        placeholder="Zoek op naam of identifier..."
        class="input"
        autocomplete="off"
      />
    </div>
    <button type="submit" class="btn btn-primary btn-sm" style="min-height:44px; padding:0 20px; white-space:nowrap;">
      Zoeken
    </button>
    <% if (zoekterm) { %>
    <a href="/llinkid" class="btn btn-secondary btn-sm" style="display:inline-flex; align-items:center; min-height:44px; padding:0 16px; white-space:nowrap; text-decoration:none;">
      Wis
    </a>
    <% } %>
  </form>

<script>
(function () {
  const input = document.getElementById('llinkid-zoek');
  if (!input) return;

  maakAutocomplete({
    inputEl:  input,
    endpoint: '/llinkid/api/suggesties?q=',
    minLen:   2,
    renderItem: function (item) {
      return {
        label: item.titel,
        sub:   item.identifier || item.uuid,
      };
    },
    onSelect: function (item) {
      // Navigeer direct naar de detailpagina van het leerplan
      window.location.href = '/llinkid/' + item.uuid;
    },
  });
})();
</script>

  <!-- Foutmelding -->
  <% if (error) { %>
  <div class="alert alert-error" style="margin-bottom:16px; font-size:0.875rem;">
    <%= error %>
  </div>
  <% } %>

  <!-- Resultaten teller -->
  <% if (leerplannen.length > 0) { %>
  <p style="font-size:0.875rem; color:#94A3B8; margin-bottom:16px;">
    <strong style="color:#0F172A; font-weight:600;"><%= leerplannen.length %></strong>
    leerplan<%= leerplannen.length !== 1 ? 'nen' : '' %> gevonden
    <% if (zoekterm) { %>voor "<strong style="color:#475569;"><%= zoekterm %></strong>"<% } %>
  </p>
  <% } else if (!error) { %>
  <p style="font-size:0.875rem; color:#94A3B8; margin-bottom:16px;">
    Geen leerplannen gevonden<%= zoekterm ? ' voor deze zoekopdracht' : '' %>.
  </p>
  <% } %>

  <!-- Grid van kaartjes -->
  <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:16px;">
    <% leerplannen.forEach(lp => { %>
    <a href="/llinkid/<%= lp.uuid %>"
       class="card"
       style="padding:18px 20px; display:flex; flex-direction:column; gap:10px; text-decoration:none; transition:box-shadow 150ms, transform 150ms;"
       onmouseover="this.style.boxShadow='0 4px 16px rgba(30,58,138,0.1)'; this.style.transform='translateY(-2px)';"
       onmouseout="this.style.boxShadow=''; this.style.transform='';">

      <h2 style="font-size:0.9375rem; font-weight:600; color:#0F172A; line-height:1.4; margin:0;">
        <%= lp.titel || 'Naamloos leerplan' %>
      </h2>

      <% if (lp.identifier) { %>
      <span class="badge badge-blue" style="width:fit-content; font-family:monospace; font-size:11px;">
        <%= lp.identifier %>
      </span>
      <% } %>

      <div style="margin-top:auto; padding-top:12px; border-top:1px solid #F1F5F9; display:flex; align-items:center; justify-content:space-between;">
        <span style="font-size:0.75rem; color:#94A3B8;">Bekijk leerplan</span>
        <svg width="14" height="14" fill="none" stroke="#CBD5E1" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    </a>
    <% }) %>
  </div>

<%- include("../partials/footer") %>
