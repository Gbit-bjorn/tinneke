<%- include('../partials/head', {title: 'Leerplan Detail', activePage: 'llinkid', flash: {}}) %>

  <!-- Broodkruimel -->
  <nav style="font-size:0.875rem; color:#94A3B8; margin-bottom:20px; display:flex; align-items:center; gap:6px; flex-wrap:wrap;">
    <a href="/llinkid" style="color:#94A3B8; text-decoration:none;">LLinkid</a>
    <span>/</span>
    <span style="color:#0F172A; font-weight:500;"><%= detail ? detail.titel : 'Detail' %></span>
  </nav>

  <% if (error) { %>
  <div class="alert alert-error" style="margin-bottom:20px;">
    <%= error %>
  </div>
  <% } %>

  <% if (detail) { %>

  <!-- Metadata kaart -->
  <div class="card" style="padding:24px; margin-bottom:20px;">
    <div style="display:flex; flex-wrap:wrap; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:16px;">
      <div>
        <h1 style="font-size:1.5rem; font-weight:700; color:#1E3A8A; margin-bottom:6px;">
          <%= detail.titel || 'Naamloos leerplan' %>
        </h1>
        <% if (detail.identifier) { %>
        <span class="badge badge-blue" style="font-family:monospace; font-size:11px;">
          <%= detail.identifier %>
        </span>
        <% } %>
      </div>
      <a href="/llinkid/<%= detail.uuid %>/doelen" class="btn btn-primary btn-sm">
        Alle doelen bekijken
      </a>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(180px, 1fr)); gap:16px; padding-top:16px; border-top:1px solid #E2E8F0;">
      <% if (detail.datum) { %>
      <div>
        <span style="display:block; font-size:0.75rem; color:#94A3B8; margin-bottom:2px;">Datum</span>
        <span style="font-weight:600; font-size:0.875rem;"><%= detail.datum %></span>
      </div>
      <% } %>
      <% if (detail.versie && Object.keys(detail.versie).length) { %>
      <div>
        <span style="display:block; font-size:0.75rem; color:#94A3B8; margin-bottom:2px;">Versie</span>
        <span style="font-weight:600; font-size:0.75rem; font-family:monospace;"><%= JSON.stringify(detail.versie) %></span>
      </div>
      <% } %>
      <div>
        <span style="display:block; font-size:0.75rem; color:#94A3B8; margin-bottom:2px;">UUID</span>
        <span style="font-size:0.75rem; font-family:monospace; color:#475569; word-break:break-all;"><%= detail.uuid %></span>
      </div>
    </div>
  </div>

  <!-- Doelen preview (eerste 10) -->
  <% if (doelen && doelen.length > 0) { %>
  <div class="card" style="padding:24px; margin-bottom:20px;">
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
      <h2 style="font-size:1.125rem; font-weight:600; color:#0F172A; margin:0;">
        Doelen
        <span class="text-secondary" style="font-size:0.875rem; font-weight:400; margin-left:6px;">(<%= doelen.length %> items)</span>
      </h2>
      <a href="/llinkid/<%= detail.uuid %>/doelen" style="font-size:0.875rem; color:#3B82F6;">Alle doelen →</a>
    </div>

    <div>
      <% doelen.slice(0, 10).forEach(doel => { %>
      <div style="display:flex; gap:12px; align-items:flex-start; padding:10px 0; border-bottom:1px solid #F1F5F9;">
        <% if (doel.is_section) { %>
        <span class="badge badge-gray" style="flex-shrink:0; margin-top:2px;">sectie</span>
        <% } else { %>
        <span class="badge badge-blue" style="flex-shrink:0; margin-top:2px; font-family:monospace;">
          <%= doel.nr || '—' %>
        </span>
        <% } %>
        <span style="font-size:0.875rem; color:#0F172A; line-height:1.5;">
          <%- (doel.titel || '(geen beschrijving)').replace(/<br\s*\/?>/g, ' ') %>
        </span>
      </div>
      <% }) %>
      <% if (doelen.length > 10) { %>
      <p class="text-secondary" style="font-size:0.875rem; padding-top:8px;">
        … en nog <%= doelen.length - 10 %> meer
      </p>
      <% } %>
    </div>
  </div>
  <% } %>

  <!-- Koppel aan klas -->
  <div class="card" style="padding:24px;">
    <h2 style="font-size:1.125rem; font-weight:600; color:#0F172A; margin-bottom:8px;">Koppel aan klas</h2>
    <p class="text-secondary" style="font-size:0.875rem; margin-bottom:16px;">Selecteer een klas om dit leerplan eraan te koppelen.</p>

    <form id="koppelForm" style="display:flex; flex-wrap:wrap; gap:12px; align-items:flex-end;">
      <div style="flex:1; min-width:200px; position:relative;">
        <label for="klasId">Klas-ID</label>
        <input
          type="text"
          id="klasId"
          name="klasId"
          placeholder="bv. KLS-001"
          class="input"
          autocomplete="off"
        >
      </div>
      <button type="submit" class="btn btn-primary">Koppelen</button>
    </form>

    <div id="koppelStatus" style="display:none; margin-top:12px; font-size:0.875rem;"></div>
  </div>

  <% } %> <%# einde if (detail) %>

  <script>
    /* Autocomplete op klasId-input → vult het veld met het klas-ID */
    (function () {
      const input = document.getElementById('klasId');
      if (!input) return;

      maakAutocomplete({
        inputEl:  input,
        endpoint: '/klassen/api/suggesties?q=',
        minLen:   1,
        debounce: 200,
        renderItem: function (item) {
          return {
            label: item.naam,
            sub:   item.richting || '',
          };
        },
        onSelect: function (item) {
          input.value = item.id;
          input.style.borderColor = '#059669';
          input.style.boxShadow   = '0 0 0 3px rgba(5,150,105,0.15)';
          setTimeout(function () {
            input.style.borderColor = '';
            input.style.boxShadow   = '';
          }, 1500);
        },
      });
    })();

    document.getElementById('koppelForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const klasId = document.getElementById('klasId').value.trim();
      const statusEl = document.getElementById('koppelStatus');
      if (!klasId) {
        statusEl.textContent = 'Vul een klas-ID in.';
        statusEl.style.cssText = 'display:block; font-size:0.875rem; color:#991B1B;';
        return;
      }

      try {
        const resp = await fetch('/llinkid/<%= detail ? detail.uuid : "" %>/koppel', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ klasId }),
        });
        const data = await resp.json();
        if (data.ok) {
          statusEl.textContent = `Gekoppeld: leerplan aan klas ${data.klasId}. ${data.boodschap || ''}`;
          statusEl.style.cssText = 'display:block; font-size:0.875rem; color:#065F46; background:#D1FAE5; border:1px solid #A7F3D0; border-radius:8px; padding:10px 14px;';
        } else {
          statusEl.textContent = `Fout: ${data.error}`;
          statusEl.style.cssText = 'display:block; font-size:0.875rem; color:#991B1B; background:#FEE2E2; border:1px solid #FECACA; border-radius:8px; padding:10px 14px;';
        }
      } catch (err) {
        statusEl.textContent = 'Verbindingsfout. Probeer opnieuw.';
        statusEl.style.cssText = 'display:block; font-size:0.875rem; color:#991B1B; background:#FEE2E2; border:1px solid #FECACA; border-radius:8px; padding:10px 14px;';
      }
    });
  </script>
<%- include("../partials/footer") %>
