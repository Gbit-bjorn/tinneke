<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aanmelden — Tinneke</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@600;700&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    * { font-family: 'Nunito', sans-serif; }
    h1, h2, .font-heading { font-family: 'Fredoka', sans-serif; }
    body { background-color: #F8FAFC; }

    .clay-card {
      background: white;
      border-radius: 24px;
      box-shadow:
        8px 8px 20px rgba(37, 99, 235, 0.12),
        -3px -3px 8px rgba(255, 255, 255, 0.85),
        inset 0 1px 0 rgba(255, 255, 255, 0.95);
      border: 2px solid rgba(255, 255, 255, 0.65);
    }
    .clay-input {
      border-radius: 12px;
      border: 2px solid #e2e8f0;
      padding: 11px 14px;
      font-family: 'Nunito', sans-serif;
      font-size: 1rem;
      width: 100%;
      background: white;
      transition: border-color 200ms, box-shadow 200ms;
      outline: none;
    }
    .clay-input:focus {
      border-color: #2563EB;
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }
    .clay-btn-cta {
      border-radius: 14px;
      font-family: 'Nunito', sans-serif;
      font-weight: 700;
      padding: 13px 20px;
      cursor: pointer;
      transition: all 200ms ease-out;
      border: none;
      background: #F97316;
      color: white;
      box-shadow: 0 4px 14px rgba(249, 115, 22, 0.35);
      font-size: 1rem;
      width: 100%;
    }
    .clay-btn-cta:hover {
      box-shadow: 0 6px 20px rgba(249, 115, 22, 0.45);
      transform: translateY(-1px);
    }
    .clay-btn-cta:active { transform: translateY(0); }

    /* Subtiel patroon achtergrond */
    .login-bg {
      background-color: #F8FAFC;
      background-image: radial-gradient(circle at 20% 30%, rgba(37,99,235,0.06) 0%, transparent 50%),
                        radial-gradient(circle at 80% 70%, rgba(249,115,22,0.05) 0%, transparent 45%);
    }
  </style>
</head>
<body class="login-bg min-h-screen flex items-center justify-center px-4">

  <div class="w-full max-w-md">

    <!-- Logo boven kaart -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-primary rounded-2xl shadow-lg mb-4"
           style="background:#2563EB; border-radius:20px; box-shadow: 0 8px 24px rgba(37,99,235,0.35);">
        <span style="font-family:'Fredoka',sans-serif; font-size:2rem; color:white; line-height:1;">T</span>
      </div>
      <h1 style="font-family:'Fredoka',sans-serif; font-size:2.5rem; font-weight:700; color:#1E293B; margin:0;">
        Tinneke
      </h1>
      <p style="color:#64748B; font-size:0.95rem; margin-top:4px;">
        Damiaaninstituut Aarschot
      </p>
    </div>

    <!-- Login kaart -->
    <div class="clay-card p-8">

      <h2 style="font-family:'Fredoka',sans-serif; font-size:1.5rem; font-weight:600; color:#1E293B; margin:0 0 6px;">
        Welkom terug
      </h2>
      <p style="color:#64748B; font-size:0.9rem; margin-bottom:28px;">
        Meld je aan om verder te gaan.
      </p>

      <!-- Foutmelding -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div style="background:rgba(239,68,68,0.08); border:2px solid rgba(239,68,68,0.25); border-radius:12px; padding:12px 14px; margin-bottom:20px; display:flex; align-items:center; gap:10px;">
          <svg xmlns="http://www.w3.org/2000/svg" style="width:18px;height:18px;flex-shrink:0;color:#DC2626;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
          </svg>
          <span style="color:#DC2626; font-weight:600; font-size:0.9rem;"><%= error %></span>
        </div>
      <% } %>

      <form action="/auth/login" method="POST" autocomplete="on">
        <!-- Gebruikersnaam -->
        <div style="margin-bottom:18px;">
          <label for="username" style="display:block; font-weight:700; font-size:0.875rem; color:#374151; margin-bottom:6px;">
            Gebruikersnaam
          </label>
          <input
            type="text"
            id="username"
            name="username"
            class="clay-input"
            placeholder="jouw.naam"
            autocomplete="username"
            required
            value="<%= typeof lastUsername !== 'undefined' ? lastUsername : '' %>"
          />
        </div>

        <!-- Wachtwoord -->
        <div style="margin-bottom:28px;">
          <label for="password" style="display:block; font-weight:700; font-size:0.875rem; color:#374151; margin-bottom:6px;">
            Wachtwoord
          </label>
          <input
            type="password"
            id="password"
            name="password"
            class="clay-input"
            placeholder="••••••••"
            autocomplete="current-password"
            required
          />
        </div>

        <button type="submit" class="clay-btn-cta">
          Aanmelden
        </button>
      </form>
    </div>

    <!-- Subtiele footer tekst -->
    <p style="text-align:center; color:#94A3B8; font-size:0.8rem; margin-top:24px;">
      Enkel toegankelijk voor medewerkers van het Damiaaninstituut
    </p>
  </div>

</body>
</html>
