<%- include('partials/head', { title: 'Dashboard', activePage: 'klassen' }) %>

<!-- ── Pagina-header ── -->
<div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:12px; margin-bottom:28px;">
  <div>
    <h1 style="font-size:26px; font-weight:700; color:#0F172A; margin:0 0 4px 0;">Mijn klassen</h1>
    <p style="font-size:14px; color:#475569; margin:0;">
      Schooljaar <strong><%= schooljaar %>&ndash;<%= schooljaar + 1 %></strong>
      &mdash; <span id="klas-teller"><%= klassen.length %></span> klas<%= klassen.length !== 1 ? 'sen' : '' %>
    </p>
  </div>
  <% if (typeof user !== 'undefined' && (user.rol === 'admin' || user.rol === 'superadmin')) { %>
  <a href="/wisa/sync" class="btn btn-primary" style="min-height:44px; display:inline-flex; align-items:center; gap:8px;">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
    </svg>
    WISA synchroniseren
  </a>
  <% } %>
</div>

<% if (klassen.length === 0) { %>

  <!-- ── Lege staat ── -->
  <div class="card" style="padding:56px 32px; text-align:center;">
    <div style="width:64px; height:64px; background:#EFF6FF; border-radius:12px; display:flex; align-items:center; justify-content:center; margin:0 auto 20px auto;">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" viewBox="0 0 24 24" stroke="#1E3A8A">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
    </div>
    <h2 style="font-size:20px; font-weight:700; color:#0F172A; margin:0 0 8px 0;">Nog geen klassen</h2>
    <p style="font-size:14px; color:#475569; margin:0 0 24px 0; max-width:360px; margin-left:auto; margin-right:auto;">
      Synchroniseer WISA om klassen en leerlingen te importeren, of maak een klas handmatig aan.
    </p>
    <% if (typeof user !== 'undefined' && (user.rol === 'admin' || user.rol === 'superadmin')) { %>
    <a href="/wisa/sync" class="btn btn-primary" style="min-height:44px; display:inline-flex; align-items:center; gap:8px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
      </svg>
      WISA synchroniseren
    </a>
    <% } %>
  </div>

<% } else { %>

  <!-- ── Filter balk ── -->
  <div class="card" style="padding:16px; margin-bottom:20px; display:flex; flex-wrap:wrap; gap:12px; align-items:center;">
    <div style="flex:1; min-width:220px; position:relative;">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#94A3B8"
           style="position:absolute; left:12px; top:50%; transform:translateY(-50%); pointer-events:none; z-index:1;">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z" />
      </svg>
      <input
        id="zoek-input"
        type="search"
        placeholder="Zoek op klasnaam of richting&hellip;"
        class="input"
        style="padding-left:36px;"
        autocomplete="off"
      />
    </div>
    <div style="flex:1; min-width:220px; position:relative;">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="#94A3B8"
           style="position:absolute; left:12px; top:50%; transform:translateY(-50%); pointer-events:none; z-index:1;">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <input
        id="zoek-leerling-input"
        type="search"
        placeholder="Zoek leerling op naam&hellip;"
        class="input"
        style="padding-left:36px;"
        autocomplete="off"
      />
    </div>
    <div style="min-width:180px;">
      <select id="schooljaar-filter" class="input">
        <option value="">Alle schooljaren</option>
        <%
          const jaarSet = new Set(klassen.map(k => k.schooljaar));
          jaarSet.add(schooljaar);
          const uniekJaren = [...jaarSet].sort((a, b) => b - a);
          uniekJaren.forEach(function(jaar) {
        %>
          <option value="<%= jaar %>" <%= jaar === schooljaar ? 'selected' : '' %>><%= jaar %>&ndash;<%= jaar + 1 %></option>
        <% }); %>
      </select>
    </div>
  </div>

  <!-- ── Klassen grid ── -->
  <div id="klassen-grid" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:16px;">
    <% klassen.forEach(function(klas) { %>
      <a href="/klassen/<%= klas.id %>" class="card card-hover klas-kaart"
           style="padding:20px; display:flex; flex-direction:column; gap:0; text-decoration:none; color:inherit;"
           data-naam="<%= klas.naam.toLowerCase() %>"
           data-richting="<%= (klas.richting || '').toLowerCase() %>"
           data-schooljaar="<%= klas.schooljaar %>">

        <!-- Kaart header -->
        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:12px;">
          <div style="min-width:0; flex:1; padding-right:10px;">
            <h2 style="font-size:17px; font-weight:700; color:#0F172A; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= klas.naam %></h2>
            <% if (klas.richting) { %>
              <p style="font-size:13px; color:#475569; margin:3px 0 0 0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= klas.richting %></p>
            <% } %>
          </div>
          <span class="badge badge-blue" style="white-space:nowrap; flex-shrink:0;">
            <%= klas.schooljaar %>&ndash;<%= klas.schooljaar + 1 %>
          </span>
        </div>

        <!-- Leerlingenteller -->
        <div style="display:flex; align-items:center; gap:6px; color:#64748B; font-size:13px; margin-bottom:8px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#1E3A8A" style="flex-shrink:0;">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197" />
          </svg>
          <span>
            <strong style="color:#0F172A;"><%= klas.aantal_leerlingen %></strong>
            leerling<%= klas.aantal_leerlingen !== 1 ? 'en' : '' %>
          </span>
        </div>

        <!-- Laatste WISA-sync -->
        <% if (klas.laatste_sync) { %>
          <div style="display:flex; align-items:center; gap:5px; color:#94A3B8; font-size:11px; margin-bottom:16px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="flex-shrink:0;">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span>Sync: <%= new Date(klas.laatste_sync).toLocaleDateString('nl-BE', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
          </div>
        <% } else { %>
          <div style="margin-bottom:16px;"></div>
        <% } %>

        <!-- Actie -->
        <div style="margin-top:auto;">
          <span class="btn btn-primary btn-sm btn-full">Bekijk klas</span>
        </div>

      </a>
    <% }); %>
  </div>

  <!-- Geen resultaten na filteren -->
  <div id="geen-resultaten" class="card" style="padding:48px 24px; text-align:center; display:none; margin-top:16px;">
    <div style="width:48px; height:48px; background:#F1F5F9; border-radius:10px; display:flex; align-items:center; justify-content:center; margin:0 auto 16px auto;">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#94A3B8">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M21 21l-4.35-4.35M17 11A6 6 0 115 11a6 6 0 0112 0z" />
      </svg>
    </div>
    <h3 style="font-size:17px; font-weight:600; color:#0F172A; margin:0 0 6px 0;">Geen klassen gevonden</h3>
    <p style="font-size:13px; color:#475569; margin:0;">Pas de zoekterm of het schooljaarfilter aan.</p>
  </div>

<% } %>

<script>
/* Dashboard: autocomplete voor zoek-input → navigeer direct naar klas */
(function () {
  const input = document.getElementById('zoek-input');
  if (!input) return;

  maakAutocomplete({
    inputEl:  input,
    endpoint: '/klassen/api/suggesties?q=',
    minLen:   1,
    debounce: 200,
    renderItem: function (item) {
      return {
        label: item.naam + (item.richting ? ' — ' + item.richting : ''),
        sub:   item.schooljaar + '–' + (item.schooljaar + 1),
      };
    },
    onSelect: function (item) {
      window.location.href = '/klassen/' + item.id;
    },
  });
})();

/* Dashboard: autocomplete voor leerling-zoek → navigeer naar attestering */
(function () {
  const input = document.getElementById('zoek-leerling-input');
  if (!input) return;

  maakAutocomplete({
    inputEl:  input,
    endpoint: '/klassen/api/leerlingen?q=',
    minLen:   2,
    debounce: 250,
    renderItem: function (item) {
      return {
        label: item.voornaam + ' ' + item.naam,
        sub:   item.klas_naam || '',
      };
    },
    onSelect: function (item) {
      window.location.href = '/attestering/' + item.id;
    },
  });
})();
</script>

<script>
(function () {
  const zoekInput        = document.getElementById('zoek-input');
  const schooljaarSelect = document.getElementById('schooljaar-filter');
  const grid             = document.getElementById('klassen-grid');
  const geenResultaten   = document.getElementById('geen-resultaten');
  const teller           = document.getElementById('klas-teller');

  if (!zoekInput || !grid) return;

  function filterKlassen() {
    const zoekterm   = zoekInput.value.trim().toLowerCase();
    const schooljaar = schooljaarSelect ? schooljaarSelect.value : '';
    const kaarten    = grid.querySelectorAll('.klas-kaart');
    let zichtbaar    = 0;

    kaarten.forEach(function (kaart) {
      const naam     = kaart.dataset.naam      || '';
      const richting = kaart.dataset.richting  || '';
      const jaar     = kaart.dataset.schooljaar || '';

      const matchZoek = !zoekterm   || naam.includes(zoekterm) || richting.includes(zoekterm);
      const matchJaar = !schooljaar || jaar === schooljaar;

      if (matchZoek && matchJaar) {
        kaart.style.display = '';
        zichtbaar++;
      } else {
        kaart.style.display = 'none';
      }
    });

    if (geenResultaten) {
      geenResultaten.style.display = zichtbaar > 0 ? 'none' : 'block';
    }
    if (teller) {
      teller.textContent = zichtbaar;
    }
  }

  zoekInput.addEventListener('input', filterKlassen);
  if (schooljaarSelect) schooljaarSelect.addEventListener('change', filterKlassen);

  // Filter direct bij laden als er een schooljaar geselecteerd is
  if (schooljaarSelect && schooljaarSelect.value) filterKlassen();
})();
</script>

<%- include('partials/footer') %>
